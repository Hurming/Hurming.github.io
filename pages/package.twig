            {% endif %} #}

            {# Preorder Notice #}
            {% if is_preorder_pending(package) %}
            <div class="flex items-center gap-3 px-4 py-3 bg-white/[0.03] border border-white/[0.06] rounded-xl">
                <div class="w-2 h-2 rounded-full bg-amber-400 animate-pulse"></div>
                <p class="text-sm text-white/70">
                    {% if package.preorder_message %}
                        {{ package.preorder_message }}
                    {% else %}
                        Available {{ format_preorder_date(package, 'M j, Y') }}
                    {% endif %}
                </p>
            </div>
            {% endif %}

            {# Info Tags #}
            <div class="flex flex-wrap gap-2">
                {% if package.one_time_purchase %}
                <div class="flex items-center gap-2 px-3 py-2 bg-white/5 rounded-lg text-sm text-white/70">
                    <svg class="w-4 h-4 accent-text" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"/></svg>
                    One-time purchase
                </div>
                {% endif %}
                {% if package.require_online %}
                <div class="flex items-center gap-2 px-3 py-2 bg-white/5 rounded-lg text-sm text-white/70">
                    <svg class="w-4 h-4 accent-text" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                    Requires online
                </div>
                {% endif %}
                {% if package.expiry_days %}
                <div class="flex items-center gap-2 px-3 py-2 bg-white/5 rounded-lg text-sm text-white/70">
                    <svg class="w-4 h-4 text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                    {{ package.expiry_days }} day duration
                </div>
                {% endif %}
            </div>

            {# Action Buttons #}
            <div class="flex flex-col sm:flex-row gap-3 pt-2">
                {# Buy Now / Pre-order Button #}
                <button
                    @click="buyNow({{ package|json_encode }})"
                    :disabled="buyingNow === {{ package.id }}"
                    class="flex-1 py-4 rounded-xl font-bold text-lg text-white transition-all hover:opacity-90 flex items-center justify-center gap-2 accent-bg"
                >
                    <span x-show="buyingNow !== {{ package.id }}">
                        <svg class="w-5 h-5 inline mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
                        {{ is_preorder_pending(package) ? 'Pre-order' : 'Buy Now' }}
                    </span>
                    <span x-show="buyingNow === {{ package.id }}" x-cloak>Processing...</span>
                </button>

                {# Add to Cart Button #}
                <button
                    @click="addItem({{ package|json_encode }})"
                    :disabled="hasItem({{ package.id }}) || loading === {{ package.id }}"
                    class="flex-1 py-4 rounded-xl font-bold text-lg transition-all flex items-center justify-center gap-2 border-2"
                    :class="hasItem({{ package.id }}) ? 'bg-white/5 text-white/40 border-white/10 cursor-not-allowed' : 'bg-transparent text-white border-white/20 hover:bg-white/5 hover:border-white/30'"
                >
                    <span x-show="!hasItem({{ package.id }}) && loading !== {{ package.id }}">
                        <svg class="w-5 h-5 inline mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
                        Add to Cart
                    </span>
                    <span x-show="hasItem({{ package.id }})" x-cloak>
                        <svg class="w-5 h-5 inline mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                        In Cart
                    </span>
                    <span x-show="loading === {{ package.id }}" x-cloak>Adding...</span>
                </button>
            </div>

            {# Wishlist Button #}
            {% if store.wishlist_enabled %}
            <div class="pt-3">
                <button
                    @click="$store.wishlist.toggle({{ package.id }})"
                    :disabled="$store.wishlist.loading === {{ package.id }}"
                    class="w-full py-3 rounded-xl font-semibold text-sm transition-all flex items-center justify-center gap-2 border"
                    :class="$store.wishlist.isWishlisted({{ package.id }}) ? 'bg-red-500/10 border-red-500/30 text-red-400 hover:bg-red-500/20' : 'bg-white/5 border-white/10 text-white/60 hover:text-white hover:border-white/20'"
                >
                    <svg x-show="$store.wishlist.loading !== {{ package.id }}" class="w-5 h-5" :class="$store.wishlist.isWishlisted({{ package.id }}) ? 'fill-current' : ''" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>
                    <svg x-show="$store.wishlist.loading === {{ package.id }}" x-cloak class="w-4 h-4 animate-spin" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path></svg>
                    <span x-show="!$store.wishlist.isWishlisted({{ package.id }})">Add to Wishlist</span>
                    <span x-show="$store.wishlist.isWishlisted({{ package.id }})" x-cloak>Remove from Wishlist</span>
                </button>
                <p class="text-center text-white/30 text-xs mt-2">Get notified when this item goes on sale</p>
            </div>
            {% endif %}
        </div>

        {# Right Column - Product Image #}
        <div class="lg:sticky lg:top-24 lg:self-start">
            <div class="relative group">
                <div class="aspect-square bg-gradient-to-br from-[#1e1e24] to-[#16161a] rounded-2xl overflow-hidden border border-white/5">
                    {% if package.image_path %}
                        <img src="{{ storage_url(package.image_path) }}" alt="{{ package.name }}" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105">
                    {% else %}
                        <div class="w-full h-full flex items-center justify-center">
                            <div class="text-center">
                                <svg class="w-24 h-24 text-white/10 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
                                <p class="text-white/30 text-sm">No image available</p>
                            </div>
                        </div>
                    {% endif %}
                </div>

                {# Badges #}
                {% if is_preorder_pending(package) %}
                    <span class="absolute top-4 left-4 px-3 py-1.5 bg-white/10 backdrop-blur-sm border border-white/10 rounded-lg text-sm font-medium text-white">
                        Pre-order
                    </span>
                {% elseif package.original_price and package.original_price > package.price %}
                    {% set discount = ((1 - package.price / package.original_price) * 100)|round %}
                    <span class="absolute top-4 left-4 px-3 py-1.5 bg-gradient-to-r from-red-500 to-orange-500 rounded-lg text-sm font-bold text-white shadow-lg">
                        -{{ discount }}% OFF
                    </span>
                {% endif %}
