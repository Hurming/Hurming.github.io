{% extends 'layouts/base.twig' %}

{% block title %}{{ package.name }} - {{ store.name }}{% endblock %}

{% block content %}
{# Nav Bar #}
{% include 'components/navbar.twig' %}

<link href="https://fonts.cdnfonts.com/css/minecraftia" rel="stylesheet">
<style>
    .grid-container {
        display: grid;
        grid-template-columns: repeat(9, 45px); 
        grid-template-rows: repeat(3, 45px);
        gap: 5px;
        padding: 10px;
        position: relative;
        overflow: visible;
    }
    .box {
        background-color: rgba(255, 255, 255, 0.05);
        border-radius: 8px;
        border: 1px solid rgba(255, 255, 255, 0.08);
        box-shadow: inset 0 0 10px rgba(255, 255, 255, 0.02);
        transition: all 0.3s ease;
        position: relative;
        z-index: 1;
    }
    .box:hover {
        background-color: rgba(255, 255, 255, 0.12);
        border-color: rgba(255, 255, 255, 0.2);
        transform: scale(1.05);
        z-index: 999;
    }

    .item-icon {
        width: 40px;
        height: 40px;
        image-rendering: pixelated;
    }

    .tooltip {
        visibility: hidden;
        position: absolute;
        z-index: 100;
        top: 110%;
        left: 50%;
        z-index: 1000;
        transform: translateX(-50%);
        width: 260px;
        background-color: rgba(17, 17, 17, 0.5); 
        backdrop-filter: blur(5px); 
        border-radius: 10px;
        overflow: hidden;
        box-shadow: 0px 10px 30px rgba(0,0,0,0.5);
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        color: #eee;
        pointer-events: none;
    }

    .tooltip-header {
        background-color: #2ecc71;
        padding: 10px;
        display: flex;
        align-items: center;
        gap: 4px;
        color: white;
        font-weight: bold;
        font-size: 20px;
    }

    .tooltip-body {
        padding: 12px;
        font-size: 12px;
        line-height: 1.6;
    }

    .stat-red { color: #ff5555; }
    .stat-green { color: #55ff55; }
    .stat-blue { color: #5555ff; }
    .stat-gold { color: #ffaa00; }

    .box:hover .tooltip {
        visibility: visible;
    }

    .enchanted-item {
        position: relative;
        display: inline-block;
        background: rgba(0, 0, 0, 0.15);
        border-radius: 4px;
    }

    .enchanted-item::after {
        content: "";
        position: absolute;
        top: 0; left: 0;
        width: 100%; height: 100%;
        
        background: linear-gradient(
            135deg,
            rgba(144, 50, 255, 0) 25%,
            rgba(144, 50, 255, 0.3) 45%,
            rgba(210, 150, 255, 0.6) 50%,
            rgba(144, 50, 255, 0.3) 55%,
            rgba(144, 50, 255, 0) 75%
        );
        
        background-size: 250% 250%;
        -webkit-mask-image: var(--item-url);
        mask-image: var(--item-url);
        
        -webkit-mask-size: contain;
        mask-size: contain;
        -webkit-mask-repeat: no-repeat;
        mask-repeat: no-repeat;
        animation: mc-glint 8s infinite linear;
        pointer-events: none;
        filter: drop-shadow(0 0 1px rgba(144, 50, 255, 0.3));
    }

    @keyframes mc-glint {
        0% { background-position: 250% 250%; }
        100% { background-position: -250% -250%; }
    }

    @font-face {
        font-family: 'Minecraft';
        src: url('https://db.onlinewebfonts.com/t/6ab5395e22703810058b8849687e148e.woff2') format('woff2');
    }
    .mc-font { font-family: 'Minecraft', sans-serif; }

    .minecraft-font {
        font-family: 'Minecraftia', sans-serif;
        text-shadow: 2px 2px 0px #3f3f3f;
    }

</style>

{# Breadcrumb #}
<div class="max-w-6xl mx-auto px-6 pt-6">
