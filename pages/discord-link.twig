{% extends "layouts/base.twig" %}

{% block title %}Link Discord - {{ store.name }}{% endblock %}

{% block content %}
<div class="min-h-screen flex flex-col">
    {# Navbar #}
    {% include 'components/navbar.twig' %}

    {# Hero Banner - Smaller #}
    <div class="relative h-[200px] sm:h-[240px]">
        {% if store.banner %}
            <img src="{{ storage_url(store.banner) }}" alt="" class="absolute inset-0 w-full h-full object-cover">
        {% else %}
            <div class="absolute inset-0 bg-gradient-to-b from-[#2a2a3e] to-[#16161a]"></div>
        {% endif %}
        <div class="absolute inset-0 bg-gradient-to-t from-[#16161a] via-[#16161a]/40 to-transparent"></div>

        <div class="absolute inset-0 flex items-center justify-center">
            <a href="/" class="hover:scale-105 transition-transform">
                {% if store.logo %}
                    <img src="{{ storage_url(store.logo) }}" alt="{{ store.name }}" class="max-h-24 sm:max-h-32 drop-shadow-2xl">
                {% else %}
                    <h1 class="text-4xl sm:text-5xl font-black text-white drop-shadow-lg">{{ store.name }}</h1>
                {% endif %}
            </a>
        </div>
    </div>

    {# Main Content #}
    <div class="max-w-2xl mx-auto px-6 py-8 flex-1 w-full">
        {# Back link #}
        <div class="mb-6">
            <a href="/" class="inline-flex items-center gap-2 text-white/60 hover:text-white transition-colors">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
                </svg>
                Back to Store
            </a>
        </div>

        <div class="bg-[#1e1e24] rounded-2xl overflow-hidden">
            {# Header #}
            <div class="p-6 sm:p-8 border-b border-white/5">
                <div class="flex items-center gap-4">
                    <div class="w-14 h-14 rounded-2xl flex items-center justify-center shrink-0 bg-[#5865F2]">
                        <svg class="w-7 h-7 text-white" viewBox="0 0 24 24" fill="currentColor">
                            <path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"/>
                        </svg>
                    </div>
                    <div>
                        <h1 class="text-2xl sm:text-3xl font-bold text-white">Link Discord</h1>
                        <p class="text-white/50 text-sm mt-1">Connect your Discord account to receive roles</p>
                    </div>
                </div>
            </div>

            {# Content #}
            <div class="p-6 sm:p-8" x-data="discordLinkPage()">
                {% if error %}
                    <div class="p-4 rounded-xl bg-red-500/10 border border-red-500/20 mb-6">
                        <p class="text-red-400 text-sm">{{ error }}</p>
                    </div>
                {% endif %}

                {% if discord_link %}
                    {# Already linked #}
                    <div class="text-center py-8">
                        <div class="w-20 h-20 rounded-full bg-green-500/10 flex items-center justify-center mx-auto mb-4">
                            <svg class="w-10 h-10 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                            </svg>
                        </div>
                        <h3 class="text-xl font-bold text-white mb-2">Discord Linked!</h3>
                        <p class="text-white/60 mb-4">Your account is linked to <span class="text-white font-semibold">{{ discord_link.discord_username }}</span></p>

                        <button @click="unlinkDiscord()" :disabled="unlinking"
                                class="px-6 py-3 rounded-xl bg-red-500/10 border border-red-500/20 text-red-400 hover:bg-red-500/20 transition-colors disabled:opacity-50">
                            <span x-show="!unlinking">Unlink Discord</span>
                            <span x-show="unlinking">Unlinking...</span>
                        </button>
                    </div>
                {% elseif player_username %}
                    {# Has username, can link #}
                    <div class="text-center py-8">
                        <p class="text-white/60 mb-2">Linking Discord for:</p>
                        <p class="text-xl font-bold text-white mb-6">{{ player_username }}</p>

                        {% if oauth_url %}
                            <a href="{{ oauth_url }}"
                               class="inline-flex items-center gap-3 px-8 py-4 rounded-xl bg-[#5865F2] hover:bg-[#4752C4] text-white font-semibold transition-colors">
                                <svg class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor">
                                    <path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"/>
                                </svg>
                                Connect with Discord
                            </a>
                        {% else %}
                            <p class="text-white/50">Discord OAuth is not configured for this store.</p>
                        {% endif %}
                    </div>
                {% else %}
                    {# Need to enter username first #}
                    <div class="py-4">
                        <p class="text-white/60 mb-6 text-center">Enter your Minecraft username to link your Discord account.</p>

                        <form @submit.prevent="setUsername()" class="space-y-4">
                            <div>
                                <label class="block text-sm font-medium text-white/70 mb-2">Minecraft Username</label>
                                <input type="text" x-model="username" required
                                       class="w-full px-4 py-3 rounded-xl bg-white/5 border border-white/10 text-white placeholder-white/30 focus:outline-none focus:border-white/20"
                                       placeholder="Enter your username">
                            </div>

                            <button type="submit" :disabled="submitting || !username"
                                    class="w-full py-4 rounded-xl font-semibold text-white transition-colors disabled:opacity-50"
                                    style="background-color: {{ store.accent_color }}">
                                <span x-show="!submitting">Continue</span>
                                <span x-show="submitting">Loading...</span>
                            </button>
                        </form>
                    </div>
                {% endif %}
            </div>
        </div>
    </div>

</div>

<script>
document.addEventListener('alpine:init', () => {
    Alpine.data('discordLinkPage', () => ({
        username: '',
        submitting: false,
        unlinking: false,

        async setUsername() {
            if (!this.username || this.submitting) return;
            this.submitting = true;

            try {
                const response = await fetch('/discord/set-username', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-CSRF-TOKEN': document.querySelector('meta[name="csrf-token"]')?.content || ''
                    },
                    body: JSON.stringify({ username: this.username })
                });

                if (response.ok) {
                    window.location.reload();
                }
            } catch (e) {
                console.error(e);
            } finally {
                this.submitting = false;
            }
        },

        async unlinkDiscord() {
            if (this.unlinking) return;
            this.unlinking = true;

            try {
                const response = await fetch('/discord/unlink', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-CSRF-TOKEN': document.querySelector('meta[name="csrf-token"]')?.content || ''
                    }
                });

                if (response.ok) {
                    window.location.reload();
                }
            } catch (e) {
                console.error(e);
            } finally {
                this.unlinking = false;
            }
        }
    }));
});
</script>
{% endblock %}