{% extends 'layouts/base.twig' %}

{% block title %}{{ store.name }}{% endblock %}

{% block content %}

<script>
    const serverIP = "arabthrone.net";
    const discordWidgetURL = "https://discord.com/api/guilds/398933283896819722/widget.json";
    const mcStatusURL = "https://api.mcstatus.io/v2/status/java/" + serverIP;

    /* Minecraft Player Count (Initial Load) */
    fetch(mcStatusURL)
        .then(res => {
            if (!res.ok) throw new Error("MC Status API Error");
            return res.json();
        })
        .then(data => {
            const playersElem = document.getElementById("playersCount");
            if (!playersElem) return;

            if (data.online) {
                playersElem.innerHTML = `<span class="text-emerald-400">${data.players.online}</span>`;
            } else {
                playersElem.innerHTML = `<span class="text-red-500">Offline</span>`;
            }
        })
        .catch(err => {
            console.error("Initial Player Fetch Error:", err);
        });

    /* Discord Online Count */
    function updateDiscord() {
        fetch(discordWidgetURL)
            .then(res => res.json())
            .then(data => {
                const discordElem = document.getElementById("discordCount");
                const discordPing = document.getElementById("discordPing");
                
                if (data && data.presence_count !== undefined) {
                    const online = data.presence_count;
                    discordElem.innerText = `${online}`;
                    if (discordPing) discordPing.style.display = 'flex';
                }
            })
            .catch(err => {
                const discordElem = document.getElementById("discordCount");
                const discordPing = document.getElementById("discordPing");
                if (discordElem) discordElem.innerText = "Offline";
                if (discordPing) discordPing.style.display = 'none';
                console.error("Discord Widget Error:", err);
            });
    }
    updateDiscord();
    setInterval(updateDiscord, 60000);

    /* Minecraft Player Count (Auto Update) */
    function updatePlayers() {
        fetch(mcStatusURL)
            .then(res => {
                if (!res.ok) throw new Error("MC Status API Error");
                return res.json();
            })
            .then(data => {
                const countElement = document.getElementById("playersCount");
                if (!countElement) return;

                countElement.innerText = data.online ? data.players.online : "0";
            })
            .catch(err => {
                console.error("Error fetching player count:", err);
                const countElement = document.getElementById("playersCount");
                if (countElement) countElement.innerText = "0";
            });
    }

    updatePlayers();
    setInterval(updatePlayers, 60000);

    /* Copy Server IP */
    function copyIP() {
        navigator.clipboard.writeText(serverIP)
            .then(() => {
                const defaultText = document.getElementById("defaultText");
                const hoverText = document.getElementById("hoverText");
                const successText = document.getElementById("successText");

                if (!defaultText || !hoverText || !successText) return;

                hoverText.classList.remove("group-hover:translate-y-0", "group-hover:opacity-100");
                hoverText.style.opacity = "0";
                hoverText.style.transform = "translateY(-100%)";
                defaultText.style.opacity = "0";

                successText.classList.remove("translate-y-full", "opacity-0");
                successText.classList.add("translate-y-0", "opacity-100");

                setTimeout(() => {
                    successText.classList.add("translate-y-full", "opacity-0");
                    successText.classList.remove("translate-y-0", "opacity-100");

                    hoverText.style.opacity = "";
                    hoverText.style.transform = "";
                    hoverText.classList.add("group-hover:translate-y-0", "group-hover:opacity-100");
                    defaultText.style.opacity = "";
                }, 2000);
            })
            .catch(err => {
                console.error("Error Copy:", err);
            });
    }
</script>

{# Hero Banner #}
<div class="relative bg-gradient-to-b from-[#252d38] via-[#1f2630] to-[#1a1f26] overflow-hidden min-h-[350px] flex items-center justify-center p-4">
    {# Background #}
    {% if store.banner %}
        <div class="absolute inset-0 opacity-30 pointer-events-none">
            <img src="{{ storage_url(store.banner) }}" alt="" class="w-full h-full object-cover">
        </div>
    {% else %}
        <div class="absolute inset-0 bg-gradient-to-b from-[#2a2a3e] to-[#16161a]"></div>
    {% endif %}

    {# Gradient overlay #}
    <div class="absolute inset-0 bg-gradient-to-t from-[#16161a] via-[#16161a]/40 to-transparent"></div>

    {# Logo #}
    <div class="absolute inset-0 flex items-center justify-center">
        {% if store.logo %}
            <img src="{{ storage_url(store.logo) }}" alt="{{ store.name }}" class="max-h-36 sm:max-h-40 drop-shadow-[0_0_20px_rgba(255,255,255,0.15)] hover:scale-110 transition-transform duration-500">
        {% else %}
            <h1 class="text-5xl sm:text-7xl font-black text-white drop-shadow-lg">{{ store.name }}</h1>
        {% endif %}
    </div>

    {# Play now - Top Left #}
    <div class="absolute top-[200px] left-[315px] flex items-center gap-4 select-none">
        <div class="relative">
            <span id="pingNode" class="absolute -top-3 -right-2 flex h-5 w-5 md:h-6 md:w-6 z-0"><span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span></span>
            <span class="absolute -top-3 -right-2 bg-green-600 text-[13px] font-bold px-1.5 py-0.5 rounded-full border-2 border-[#1abc9c] z-10 shadow-[0_0_10px_rgba(22,163,74,0.5)]"><div id="playersCount" class="text-white drop-shadow">Loading...</div></span>

            <div class="w-14 h-14 rounded-2xl bg-[#1abc9c] flex items-center justify-center shadow-lg transition-transform hover:scale-105">
                <svg class="w-7 h-7 text-white" viewBox="0 0 24 24" fill="currentColor"><path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/></svg></div>
        </div>

        <div class="text-left leading-tight">
            <h3 class="font-bold text-white text-base md:text-xl drop-shadow uppercase tracking-wide mb-0.5">Play Now</h3>
            <div id="copyContainer" class="group relative h-6 overflow-hidden cursor-pointer" onclick="copyIP('arabthrone.net')">
                <div id="defaultText" class="text-gray-400 font-bold text-xs md:text-sm tracking-widest uppercase transition-all duration-300 group-hover:-translate-y-full group-hover:opacity-0">arabthrone.net</div>
                <div id="hoverText" class="absolute inset-0 text-yellow-400 font-bold text-xs md:text-sm tracking-widest uppercase transition-all duration-300 translate-y-full opacity-0 group-hover:translate-y-0 group-hover:opacity-100 whitespace-nowrap">Click to Copy IP</div>
                <div id="successText" class="absolute inset-0 text-green-400 font-bold text-xs md:text-sm tracking-widest uppercase transition-all duration-300 translate-y-full opacity-0 pointer-events-none">Copied!</div>
            </div>
        </div>
    </div>
    
    {# Discord - Top Right #}
    {% if store.discord_url %}
    <div class="absolute top-[200px] right-[315px] flex items-center gap-4 select-none">
        <div class="text-right leading-tight">
            <div class="font-bold text-white text-base md:text-xl drop-shadow uppercase tracking-wide">Discord</div>
            <div class="group relative h-6 overflow-hidden cursor-pointer" onclick="window.open('{{ store.discord_url }}')">
                <div class="text-indigo-400 font-bold text-base text-xs md:text-sm tracking-widest uppercase">Click to join Now</div>
            </div>
        </div>
        <div class="relative">
            <span id="discordPing" class="absolute -top-3 -left-2 flex h-5 w-5 md:h-6 md:w-6 z-0"><span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-[#5865F2] opacity-75"></span></span>
            <span class="absolute -top-3 -left-2 bg-[#5868F2] text-[13px] font-bold px-1.5 py-0.5 rounded-full border-2 border-[#5865F2] z-10 shadow-[0_0_10px_rgba(22,163,74,0.5)]"><div id="discordCount" class="text-white drop-shadow">Loading...</div></span>
            <div class="w-14 h-14 rounded-2xl bg-[#5865F2] flex items-center justify-center shadow-lg transition-transform hover:scale-105">
                <svg class="w-7 h-7 text-white" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"/>
                </svg>
            </div>
        </div>
    </div>
    {% endif %}
</div>

{# Nav Bar #}
{% include 'components/navbar.twig' %}

{# Flash Sale Banner #}
{% if flash_sale %}
<div class="max-w-7xl mx-auto px-4 sm:px-6 pt-4 sm:pt-6" x-data="flashSaleCountdown({{ flash_sale.seconds_remaining }})">
    <div class="bg-gradient-to-r from-amber-500 via-orange-500 to-red-500 rounded-2xl p-4 sm:p-5 relative overflow-hidden">
        {# Animated background stripes #}
        <div class="absolute inset-0 opacity-10">
            <div class="absolute inset-0" style="background: repeating-linear-gradient(45deg, transparent, transparent 10px, rgba(255,255,255,0.1) 10px, rgba(255,255,255,0.1) 20px); animation: stripe-slide 2s linear infinite;"></div>
        </div>

        <div class="relative flex flex-col sm:flex-row items-center justify-between gap-3 sm:gap-4">
            <div class="flex items-center gap-3 sm:gap-4">
                <div class="w-10 h-10 sm:w-12 sm:h-12 rounded-xl bg-white/20 flex items-center justify-center animate-pulse shrink-0">
                    <svg class="w-5 h-5 sm:w-6 sm:h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
                </div>
                <div class="text-center sm:text-left">
                    <div class="text-white/80 text-[10px] sm:text-xs uppercase tracking-wider font-semibold">⚡ Flash Sale</div>
                    <div class="text-white text-base sm:text-xl font-black">{{ flash_sale.name }}</div>
                    <div class="text-white/80 text-xs sm:text-sm font-medium">{{ flash_sale.discount_type == 'percentage' ? flash_sale.discount_value ~ '% OFF' : '$' ~ flash_sale.discount_value ~ ' OFF' }} {{ flash_sale.package_ids ? 'select items' : 'everything' }}!</div>
                </div>
            </div>

            {# Countdown Timer #}
            <div class="flex items-center gap-1.5 sm:gap-3 text-center">
                <div class="bg-white/20 backdrop-blur rounded-lg sm:rounded-xl px-2 sm:px-4 py-1.5 sm:py-2 min-w-[50px] sm:min-w-[70px]">
                    <div class="text-lg sm:text-2xl font-black text-white" x-text="hours.toString().padStart(2, '0')">00</div>
                    <div class="text-[8px] sm:text-[10px] text-white/80 uppercase tracking-wider">Hours</div>
                </div>
                <span class="text-lg sm:text-2xl text-white font-bold">:</span>
                <div class="bg-white/20 backdrop-blur rounded-lg sm:rounded-xl px-2 sm:px-4 py-1.5 sm:py-2 min-w-[50px] sm:min-w-[70px]">
                    <div class="text-lg sm:text-2xl font-black text-white" x-text="minutes.toString().padStart(2, '0')">00</div>
                    <div class="text-[8px] sm:text-[10px] text-white/80 uppercase tracking-wider">Mins</div>
                </div>
                <span class="text-lg sm:text-2xl text-white font-bold">:</span>
                <div class="bg-white/20 backdrop-blur rounded-lg sm:rounded-xl px-2 sm:px-4 py-1.5 sm:py-2 min-w-[50px] sm:min-w-[70px]">
                    <div class="text-lg sm:text-2xl font-black text-white" x-text="seconds.toString().padStart(2, '0')">00</div>
                    <div class="text-[8px] sm:text-[10px] text-white/80 uppercase tracking-wider">Secs</div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endif %}

{# Package Upgrade Banner - Shows available upgrades for players #}
<div x-data="{ init() { const savedUsername = localStorage.getItem('mcsets_username'); if (savedUsername) { $store.upgrades.fetchOffers(savedUsername); } } }" x-init="init()">
    <template x-if="$store.upgrades.offers.length > 0">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 pt-4 sm:pt-6">
            <template x-for="offer in $store.upgrades.offers" :key="offer.existing_package.id">
                <div x-show="!$store.upgrades.dismissedOffers.includes(offer.existing_package.id)"
                     class="bg-gradient-to-r from-emerald-600 via-teal-600 to-cyan-600 rounded-2xl p-4 sm:p-5 mb-3 relative overflow-hidden">
                    <button @click="$store.upgrades.dismissOffer(offer.existing_package.id)"
                            class="absolute top-3 right-3 w-8 h-8 rounded-full bg-white/20 hover:bg-white/30 flex items-center justify-center text-white transition-colors">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                    </button>
                    <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
                        <div class="flex items-center gap-4">
                            <div class="w-12 h-12 rounded-xl bg-white/20 flex items-center justify-center shrink-0">
                                <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 10l7-7m0 0l7 7m-7-7v18"/></svg>
                            </div>
                            <div class="text-center sm:text-left">
                                <div class="text-white/80 text-xs uppercase tracking-wider font-semibold">Upgrade Available!</div>
                                <div class="text-white text-lg font-black">Upgrade to <span x-text="offer.upgrade_package.name"></span></div>
                                <div class="text-white/80 text-sm">
                                    You already own <span x-text="offer.existing_package.name" class="font-semibold"></span> —
                                    <template x-if="offer.savings > 0">
                                        <span>Save <span x-text="$store.upgrades.formatPrice(offer.savings)" class="font-bold"></span>!</span>
                                    </template>
                                </div>
                            </div>
                        </div>
                        <a :href="'/package/' + offer.upgrade_package.slug"
                           class="px-6 py-3 bg-white text-emerald-700 font-bold rounded-xl hover:bg-white/90 transition-colors whitespace-nowrap flex items-center gap-2">
                            <span>Upgrade for <span x-text="$store.upgrades.formatPrice(offer.upgrade_package.upgrade_price)"></span></span>
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
                        </a>
                    </div>
                </div>
            </template>
        </div>
    </template>
</div>

{# Package Upgrade Modal - Shows when user clicks on a package they already own #}
<div x-show="$store.upgrades.showModal" x-cloak
     class="fixed inset-0 z-50 flex items-center justify-center p-4"
     @keydown.escape.window="$store.upgrades.closeModal()">
    <div class="absolute inset-0 bg-black/70 backdrop-blur-sm" @click="$store.upgrades.closeModal()" x-transition.opacity></div>
    <div class="relative bg-[#1e1e24] rounded-2xl w-full max-w-lg overflow-hidden shadow-2xl border border-white/10" x-transition>
        <template x-if="$store.upgrades.currentOffer">
            <div>
                <div class="bg-gradient-to-r from-emerald-600 to-teal-600 p-6 text-center">
                    <div class="w-16 h-16 rounded-2xl bg-white/20 flex items-center justify-center mx-auto mb-4">
                        <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 10l7-7m0 0l7 7m-7-7v18"/></svg>
                    </div>
                    <h3 class="text-2xl font-black text-white mb-2">Upgrade Available!</h3>
                    <p class="text-white/80">You already own <span x-text="$store.upgrades.currentOffer.existing_package.name" class="font-semibold"></span></p>
                </div>
                <div class="p-6">
                    <div class="bg-black/20 rounded-xl p-4 mb-6">
                        <div class="flex items-center justify-between mb-3">
                            <span class="text-white/60 text-sm">Upgrade to:</span>
                            <span class="text-white font-bold text-lg" x-text="$store.upgrades.currentOffer.upgrade_package.name"></span>
                        </div>
                        <div class="flex items-center justify-between mb-3">
                            <span class="text-white/60 text-sm">Original Price:</span>
                            <span class="text-white/60 line-through" x-text="$store.upgrades.formatPrice($store.upgrades.currentOffer.upgrade_package.original_price)"></span>
                        </div>
                        <template x-if="$store.upgrades.currentOffer.savings > 0">
                            <div class="flex items-center justify-between mb-3">
                                <span class="text-white/60 text-sm">Your Savings:</span>
                                <span class="text-emerald-400 font-semibold" x-text="'-' + $store.upgrades.formatPrice($store.upgrades.currentOffer.savings)"></span>
                            </div>
                        </template>
                        <div class="border-t border-white/10 pt-3 flex items-center justify-between">
                            <span class="text-white font-semibold">Upgrade Price:</span>
                            <span class="text-2xl font-black text-emerald-400" x-text="$store.upgrades.formatPrice($store.upgrades.currentOffer.upgrade_package.upgrade_price)"></span>
                        </div>
                    </div>
                    <div class="flex gap-3">
                        <button @click="$store.upgrades.dismissOffer($store.upgrades.currentOffer.existing_package.id)"
                                class="flex-1 px-4 py-3 bg-white/5 hover:bg-white/10 text-white rounded-xl font-semibold transition-colors">
                            No Thanks
                        </button>
                        <a :href="'/package/' + $store.upgrades.currentOffer.upgrade_package.slug"
                           @click="$store.upgrades.closeModal()"
                           class="flex-1 px-4 py-3 bg-gradient-to-r from-emerald-500 to-teal-500 hover:from-emerald-600 hover:to-teal-600 text-white rounded-xl font-semibold transition-colors text-center">
                            Upgrade Now
                        </a>
                    </div>
                </div>
            </div>
        </template>
    </div>
</div>

{# Main Content #}
<div class="max-w-7xl mx-auto px-4 sm:px-6 py-6 sm:py-8">
    <div class="flex gap-6">
        {# Sidebar #}
        <aside class="hidden lg:block w-[340px] shrink-0 space-y-5">
            {% include 'components/category-sidebar.twig' %}

            {% if donations.enabled|default(false) %}
            {# Donation Goal (if set) #}
            {% if donation_goal %}
            <div class="bg-[#1e1e24] rounded-2xl p-5">
                <div class="flex items-center gap-3 mb-4">
                    <div class="w-11 h-11 rounded-xl bg-red-500/10 flex items-center justify-center">
                        <svg class="w-5 h-5 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>
                    </div>
                    <div>
                        <p class="text-[11px] text-white/40 uppercase tracking-wider font-semibold">{{ donation_goal.name }}</p>
                        <p class="font-bold text-white">{{ price(donation_goal.current) }} / {{ price(donation_goal.target) }}</p>
                    </div>
                </div>
                <div class="w-full bg-white/5 rounded-full h-3 overflow-hidden">
                    <div class="h-full bg-gradient-to-r from-red-500 to-pink-500 rounded-full transition-all duration-500" style="width: {{ donation_goal.percentage }}%"></div>
                </div>
                <p class="text-white/30 text-xs mt-2 text-center">{{ donation_goal.percentage }}% Complete</p>
            </div>
            {% endif %}

            {# Top Donator #}
            <div class="bg-[#1e1e24] rounded-2xl p-5">
                <div class="flex items-center gap-3">
                    <img src="{{ top_donator ? top_donator.avatar_url : 'https://mc-heads.net/avatar/MHF_Question/44' }}" alt="" class="w-11 h-11 rounded-xl">
                    <div>
                        <p class="text-[11px] text-white/40 uppercase tracking-wider font-semibold">Top Donator</p>
                        <p class="font-bold text-white">{{ top_donator.username|default('Nobody yet') }}</p>
                        {% if top_donator.total_amount|default(0) > 0 %}
                        <p class="text-xs text-white/40">{{ price(top_donator.total_amount) }} total</p>
                        {% endif %}
                    </div>
                </div>
            </div>

            {# Recent Payments #}
            <div class="bg-[#1e1e24] rounded-2xl p-5">
                <div class="flex items-center gap-3 mb-4">
                    <div class="w-11 h-11 rounded-xl bg-[#2a2a34] flex items-center justify-center">
                        <svg class="w-5 h-5 text-white/40" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v13m0-13V6a2 2 0 112 2h-2zm0 0V5.5A2.5 2.5 0 109.5 8H12zm-7 4h14M5 12a2 2 0 110-4h14a2 2 0 110 4M5 12v7a2 2 0 002 2h10a2 2 0 002-2v-7"/></svg>
                    </div>
                    <div>
                        <p class="text-[11px] text-white/40 uppercase tracking-wider font-semibold">Recent Payments</p>
                        <p class="font-bold text-white">Payment Feed</p>
                    </div>
                </div>
                <div class="flex gap-2">
                    {% if recent_payments|default([])|length > 0 %}
                        {% for payment in recent_payments|slice(0, 4) %}
                            <img src="{{ mc_head(payment.username, 44) }}" alt="{{ payment.username }}" class="w-11 h-11 rounded-xl" title="{{ payment.username }} - {{ price(payment.amount) }}">
                        {% endfor %}
                    {% else %}
                        <div class="w-11 h-11 rounded-xl bg-[#2a2a34]"></div>
                        <div class="w-11 h-11 rounded-xl bg-[#2a2a34]"></div>
                        <div class="w-11 h-11 rounded-xl bg-[#2a2a34]"></div>
                    {% endif %}
                </div>
            </div>
            {% endif %}

            {# Gift Cards #}
            {% if gift_cards.enabled|default(false) %}
            <div class="bg-[#1e1e24] rounded-2xl p-5" x-data="giftCardPurchase()">
                <div class="flex items-center gap-3 mb-4">
                    <div class="w-11 h-11 rounded-xl bg-purple-500/10 flex items-center justify-center">
                        <svg class="w-5 h-5 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v13m0-13V6a2 2 0 112 2h-2zm0 0V5.5A2.5 2.5 0 109.5 8H12zm-7 4h14M5 12a2 2 0 110-4h14a2 2 0 110 4M5 12v7a2 2 0 002 2h10a2 2 0 002-2v-7"/></svg>
                    </div>
                    <div>
                        <p class="text-[11px] text-white/40 uppercase tracking-wider font-semibold">Gift Cards</p>
                        <p class="font-bold text-white">Buy a Gift Card</p>
                    </div>
                </div>
                <p class="text-white/50 text-sm mb-4">Purchase a gift card for yourself or a friend!</p>
                <div class="grid grid-cols-2 gap-2 mb-4">
                    {% for amount in gift_cards.amounts %}
                    <button
                        @click="selectAmount({{ amount }})"
                        :class="selectedAmount === {{ amount }} ? 'ring-2 ring-purple-500 bg-purple-500/20' : 'bg-[#2a2a34] hover:bg-[#2a2a34]/80'"
                        class="px-4 py-3 rounded-xl text-center transition-all"
                    >
                        <span class="font-bold text-white">{{ price(amount) }}</span>
                    </button>
                    {% endfor %}
                </div>
                <button
                    @click="purchaseGiftCard()"
                    :disabled="!selectedAmount || loading || success"
                    class="w-full py-3 rounded-xl font-semibold text-white transition-all disabled:opacity-50 disabled:cursor-not-allowed"
                    :class="success ? 'bg-green-500' : (selectedAmount ? 'bg-gradient-to-r from-purple-500 to-pink-500 hover:from-purple-600 hover:to-pink-600' : 'bg-[#2a2a34]')"
                >
                    <span x-show="!loading && !success">Add to Cart</span>
                    <span x-show="success" class="flex items-center justify-center gap-2">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                        Added! Redirecting...
                    </span>
                    <span x-show="loading" class="flex items-center justify-center gap-2">
                        <svg class="animate-spin w-4 h-4" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
                        Adding...
                    </span>
                </button>
                <p x-show="error" x-text="error" class="text-red-400 text-sm mt-2 text-center"></p>
            </div>
            {% endif %}
        </aside>

        {# Main Area #}
        <main class="flex-1 min-w-0 space-y-4 sm:space-y-5">
            {# Help Banner #}
            <div class="bg-[#1e1e24] rounded-2xl p-4 sm:p-5 flex items-center gap-3 sm:gap-4">
                <div class="w-9 h-9 sm:w-10 sm:h-10 rounded-xl bg-[#2a2a34] flex items-center justify-center shrink-0">
                    <svg class="w-4 h-4 sm:w-5 sm:h-5 text-white/40" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                </div>
                <div>
                    <p class="text-[10px] sm:text-[11px] text-white/40 uppercase tracking-wider font-semibold"><span class="block">If you require <span class="text-white font-semibold">assistance</span>, encounter <span class="text-white font-semibold">any issues</span>, or have<span class="text-white font-semibold"> questions</span> regarding your purchase, our support team is available on Join our <a href="https://discord.gg/DpdxEMB" target="_blank" style="color:#5865F2; text-decoration:none;">Discord</a> for support and announcements</span></p>
                </div>
            </div>

            {# Welcome Card #}

            <div class="bg-[#1e1e24] rounded-2xl p-5 sm:p-8">
                <p class="text-xs sm:text-sm font-semibold uppercase tracking-wider mb-2 accent-text">
                    {% if active_category.description %}
                        <h2 class="text-2xl sm:text-3xl lg:text-4xl font-black text-white mb-3 sm:mb-4">{{ active_category ? active_category.name|upper : store.name|upper }}</h2>
                        <p class="text-white/50 leading-relaxed text-sm sm:text-base">{{ active_category.description|default(store.description)|default(trans('store.browse_support')) }}</p>
                    {% else %}
                        <h2 class="text-2xl sm:text-3xl lg:text-4xl font-black text-white mb-3 sm:mb-4">{{ active_category ? active_category.name|upper : store.name|upper }}</h2>

                        <p class="text-white/50 leading-relaxed text-sm sm:text-base text-left">
                            <span class="block">
                                Welcome to the <span class="text-white font-semibold">Official Portal</span> of the <span class="text-emerald-400 font-semibold">Arab Throne Network</span>, your all-in-one destination for <span class="text-white font-semibold">community engagement</span>, server news, and exclusive content.
                            </span>
                            <br>
                            <span class="block">
                                Beyond our store, this platform serves as the gateway to join our <span class="text-yellow-400 font-semibold">Staff Team</span>, participate in <span class="text-yellow-400 font-semibold">Creator Programs</span>, and access <span class="text-yellow-400 font-semibold">Premium Services</span> designed to elevate your journey within our world.
                            </span>
                            <br>
                            <span class="block">
                                Whether you are here to <span class="text-sky-400 font-semibold">apply for a rank</span> or support our growth, everything is managed through <span class="text-sky-400 font-semibold">automated systems</span> to ensure a seamless and professional experience for every player.
                            </span>
                        </p>
                    {% endif %}
                </p>
            </div>

            {# Content Sections - Above Packages #}
            {% for section in sections_above_packages|default([]) %}
            <div class="bg-[#1e1e24] rounded-2xl p-5 sm:p-8">
                {% if section.subtitle %}
                <p class="text-xs sm:text-sm font-semibold uppercase tracking-wider mb-2 accent-text">{{ section.subtitle }}</p>
                {% endif %}
                <h2 class="text-2xl sm:text-3xl lg:text-4xl font-black text-white mb-3 sm:mb-4">{{ section.title|upper }}</h2>
                {% if section.description %}
                <p class="text-white/50 leading-relaxed text-sm sm:text-base">{{ section.description }}</p>
                {% endif %}
            </div>
            {% endfor %}

            {# Featured Packages #}
            {% if featured_packages|default([])|length > 0 %}
            <div class="space-y-4">
                <h3 class="text-lg font-bold text-white flex items-center gap-2">
                    <svg class="w-5 h-5 text-amber-400" fill="currentColor" viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                    Featured
                </h3>
                <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-4">
                    {% for package in featured_packages %}
                        {% include 'components/package-card.twig' with { package: package, featured: true } %}
                    {% endfor %}
                </div>
            </div>
            {% endif %}

            {# Content Sections - Below Featured #}
            {% for section in sections_below_featured|default([]) %}
            <div class="bg-[#1e1e24] rounded-2xl p-5 sm:p-8">
                {% if section.subtitle %}
                <p class="text-xs sm:text-sm font-semibold uppercase tracking-wider mb-2 accent-text">{{ section.subtitle }}</p>
                {% endif %}
                <h2 class="text-2xl sm:text-3xl lg:text-4xl font-black text-white mb-3 sm:mb-4">{{ section.title|upper }}</h2>
                {% if section.description %}
                <p class="text-white/50 leading-relaxed text-sm sm:text-base">{{ section.description }}</p>
                {% endif %}
            </div>
            {% endfor %}

            {# Packages - Only show non-featured packages when featured section exists #}
            {% if packages|length == 0 %}
                <div class="bg-[#1e1e24] rounded-2xl p-16 text-center">
                    <svg class="w-16 h-16 text-white/10 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v13m0-13V6a2 2 0 112 2h-2zm0 0V5.5A2.5 2.5 0 109.5 8H12zm-7 4h14M5 12a2 2 0 110-4h14a2 2 0 110 4M5 12v7a2 2 0 002 2h10a2 2 0 002-2v-7"/></svg>
                    <p class="text-white/40 text-lg font-medium">No packages available</p>
                </div>
            {% elseif featured_packages|default([])|length > 0 %}
                {# Count non-featured packages #}
                {% set has_regular = false %}
                {% for package in packages %}
                    {% if not package.is_featured|default(false) %}
                        {% set has_regular = true %}
                    {% endif %}
                {% endfor %}
                {% if has_regular %}
                {# <div class="space-y-4">
                    <h3 class="text-lg font-bold text-white">All Packages</h3>
                    <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-4">
                        {% for package in packages %}
                            {% if not package.is_featured|default(false) %}
                                {% include 'components/package-card.twig' with { package: package } %}
                            {% endif %}
                        {% endfor %}
                    </div>
                </div> #}
                {% endif %}
            {% else %}
                <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-4">
                    {% for package in packages %}
                        {% include 'components/package-card.twig' with { package: package } %}
                    {% endfor %}
                </div>
            {% endif %}

            {# Content Sections - Below Packages #}
            {% for section in sections_below_packages|default([]) %}
            <div class="bg-[#1e1e24] rounded-2xl p-5 sm:p-8">
                {% if section.subtitle %}
                <p class="text-xs sm:text-sm font-semibold uppercase tracking-wider mb-2 accent-text">{{ section.subtitle }}</p>
                {% endif %}
                <h2 class="text-2xl sm:text-3xl lg:text-4xl font-black text-white mb-3 sm:mb-4">{{ section.title|upper }}</h2>
                {% if section.description %}
                <p class="text-white/50 leading-relaxed text-sm sm:text-base">{{ section.description }}</p>
                {% endif %}
            </div>
            {% endfor %}
        </main>
    </div>
</div>

{% endblock %}