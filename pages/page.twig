{% extends "layouts/base.twig" %}

{% block title %}{{ page.title }} - {{ store.name }}{% endblock %}

{% block content %}
<div class="min-h-screen flex flex-col">
    {# Navbar #}
    {% include 'components/navbar.twig' %}

    {# Hero Banner - Smaller for pages #}
    <div class="relative h-[200px] sm:h-[240px]">
        {% if store.banner %}
            <img src="{{ storage_url(store.banner) }}" alt="" class="absolute inset-0 w-full h-full object-cover">
        {% else %}
            <div class="absolute inset-0 bg-gradient-to-b from-[#2a2a3e] to-[#16161a]"></div>
        {% endif %}
        <div class="absolute inset-0 bg-gradient-to-t from-[#16161a] via-[#16161a]/40 to-transparent"></div>

        {# Logo #}
        <div class="absolute inset-0 flex items-center justify-center">
            <a href="/" class="hover:scale-105 transition-transform">
                {% if store.logo %}
                    <img src="{{ storage_url(store.logo) }}" alt="{{ store.name }}" class="max-h-24 sm:max-h-32 drop-shadow-2xl">
                {% else %}
                    <h1 class="text-4xl sm:text-5xl font-black text-white drop-shadow-lg">{{ store.name }}</h1>
                {% endif %}
            </a>
        </div>
    </div>

    {# Main Content #}
    <div class="max-w-7xl mx-auto px-6 py-8 flex-1 w-full">
        <div class="flex gap-6">
            {% if page.slug != 'social' and page.slug != 'staff' %}
                {# Sidebar - Pages Navigation #}
                <aside class="hidden lg:block w-[300px] shrink-0">
                    <div class="bg-[#1e1e24] rounded-2xl overflow-hidden sticky top-6">
                        <div class="p-6 text-center border-b border-white/5">
                            <h3 class="text-xl font-bold text-white mb-1">Pages</h3>
                            <p class="text-white/40 text-sm">Legal & Information</p>
                        </div>
                        <div class="p-3 space-y-1">
                            <a href="/" class="flex items-center px-4 py-3 rounded-xl transition-colors font-medium text-white/50 hover:text-white hover:bg-white/5">← Back to Store</a>
                            <a href="/p/terms" class="flex items-center px-4 py-3 rounded-xl transition-colors font-medium text-white/50 hover:text-white hover:bg-white/5">Terms of Service</a>
                            <a href="/p/privacy" class="flex items-center px-4 py-3 rounded-xl transition-colors font-medium text-white/50 hover:text-white hover:bg-white/5">Privacy Policy</a>
                            <a href="/p/refunds" class="flex items-center px-4 py-3 rounded-xl transition-colors font-medium text-white/50 hover:text-white hover:bg-white/5">Refund Policy</a>

                            {# {% for fp in footer_pages %}
                                <a href="/p/{{ fp.slug }}"
                                class="flex items-center px-4 py-3 rounded-xl transition-colors font-medium {% if fp.slug == page.slug %}text-white{% else %}text-white/50 hover:text-white hover:bg-white/5{% endif %}"
                                {% if fp.slug == page.slug %}style="background-color: {{ store.accent_color }}"{% endif %}>
                                    {{ fp.title }}
                                </a>
                            {% endfor %} #}
                        </div>
                    </div>
                </aside>
            {% endif %}

            {# Content #}
            <main class="flex-1 min-w-0">
                {# Mobile back button #}
                <div class="lg:hidden mb-4"><a href="/" class="inline-flex items-center gap-2 text-white/60 hover:text-white transition-colors"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>Back to Store</a></div>

                <div class="bg-[#1e1e24] rounded-2xl overflow-hidden">
                    {# Header #}
                    <div class="p-6 sm:p-8 border-b border-white/5">
                        <div class="flex items-center gap-4">
                            <div class="w-14 h-14 rounded-2xl flex items-center justify-center shrink-0" style="background-color: {{ store.accent_color }}20">
                                {% if page.template == 'terms' %}
                                    <svg class="w-7 h-7" style="color: {{ store.accent_color }}" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                                    </svg>
                                {% elseif page.template == 'privacy' %}
                                    <svg class="w-7 h-7" style="color: {{ store.accent_color }}" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
                                    </svg>
                                {% elseif page.template == 'refund' %}
                                    <svg class="w-7 h-7" style="color: {{ store.accent_color }}" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h10a8 8 0 018 8v2M3 10l6 6m-6-6l6-6"/>
                                    </svg>
                                {% else %}
                                    <svg class="w-7 h-7" style="color: {{ store.accent_color }}" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                                    </svg>
                                {% endif %}
                            </div>
                            <div>
                                <h1 class="text-2xl sm:text-3xl font-bold text-white">{{ page.title }}</h1>
                            </div>
                        </div>
                    </div>

                    {# Content #}
                    <div class="p-6 sm:p-8 prose prose-invert max-w-none">
                        <div class="text-white/70 leading-relaxed [&>h1]:text-2xl [&>h1]:font-bold [&>h1]:text-white [&>h1]:mt-8 [&>h1]:mb-4 [&>h1:first-child]:mt-0 [&>h2]:text-xl [&>h2]:font-bold [&>h2]:text-white [&>h2]:mt-6 [&>h2]:mb-3 [&>h3]:text-lg [&>h3]:font-semibold [&>h3]:text-white [&>h3]:mt-4 [&>h3]:mb-2 [&>p]:my-3 [&>ul]:list-disc [&>ul]:list-inside [&>ul]:space-y-1 [&>ul]:my-3 [&>ul]:ml-2 [&>ol]:list-decimal [&>ol]:list-inside [&>ol]:space-y-1 [&>ol]:my-3 [&>ol]:ml-2 [&>strong]:text-white [&>strong]:font-semibold">
                            {{ page.content|raw }}
                        </div>
                    </div>
                </div>
            </main>
        </div>
    </div>

</div>
{% endblock %}