{% extends "layouts/base.twig" %}

{% block title %}Gift Cards - {{ store.name }}{% endblock %}

{% block content %}
{# Nav Bar #}
{% include 'components/navbar.twig' %}

<div class="min-h-screen" x-data="giftCardPage()">
    {# Hero Section #}
    <div class="relative overflow-hidden border-b border-white/5">
        <div class="absolute inset-0 bg-gradient-to-br from-purple-600/10 via-transparent to-pink-600/10"></div>
        <div class="max-w-5xl mx-auto px-6 py-16 relative">
            <h1 class="text-5xl font-black text-white mb-3">Gift Cards</h1>
            <p class="text-white/50 text-lg max-w-xl">The perfect gift for any Minecraft player. Buy a gift card and share the code, or check your existing balance.</p>
        </div>
    </div>

    <div class="max-w-5xl mx-auto px-6 py-12">
        <div class="grid grid-cols-1 lg:grid-cols-5 gap-8">
            {# Purchase Section - Takes more space #}
            <div class="lg:col-span-3">
                <div class="bg-[#1e1e24] rounded-2xl border border-white/5 overflow-hidden">
                    <div class="p-6 border-b border-white/5">
                        <h2 class="text-lg font-bold text-white">Buy Gift Card</h2>
                        <p class="text-white/40 text-sm mt-1">Select an amount to add to your cart</p>
                    </div>
                    <div class="p-6">
                        {# Amount Selection Grid #}
                        <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-6">
                            {% for amount in gift_cards.amounts %}
                            <button
                                @click="selectedAmount = {{ amount }}"
                                :class="selectedAmount === {{ amount }} ? 'border-2 border-purple-500 bg-purple-500/5' : 'border border-white/10 hover:border-white/20'"
                                class="relative p-5 rounded-xl text-center transition-all group"
                            >
                                <div class="text-2xl font-black text-white">${{ amount }}</div>
                                <div x-show="selectedAmount === {{ amount }}" class="absolute -top-1 -right-1 w-5 h-5 rounded-full bg-purple-500 flex items-center justify-center">
                                    <svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/></svg>
                                </div>
                            </button>
                            {% endfor %}
                        </div>

                        {# Add to Cart #}
                        <button
                            @click="addToCart()"
                            :disabled="!selectedAmount || addingToCart"
                            :class="(!selectedAmount || addingToCart) ? 'opacity-40 cursor-not-allowed' : 'hover:opacity-90'"
                            class="w-full py-4 rounded-xl accent-bg text-white font-bold transition-all"
                        >
                            <span x-show="!addingToCart">Add to Cart</span>
                            <span x-show="addingToCart" class="flex items-center justify-center gap-2">
                                <svg class="w-5 h-5 animate-spin" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path></svg>
                                Adding...
                            </span>
                        </button>

                        {# Success Toast #}
                        <div x-show="addedSuccess" x-cloak x-transition class="mt-4 p-3 rounded-xl bg-green-500/10 border border-green-500/20 text-center">
                            <span class="text-green-400 text-sm font-medium">Added to cart!</span>
                        </div>
                    </div>
                </div>

                {# Info Cards #}
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mt-6">
                    <div class="bg-[#1e1e24] rounded-xl p-5 border border-white/5">
                        <div class="w-10 h-10 rounded-lg bg-purple-500/10 flex items-center justify-center mb-3">
                            <svg class="w-5 h-5 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                        </div>
                        <h3 class="font-semibold text-white mb-1">No Expiration</h3>
                        <p class="text-white/40 text-sm">Gift cards are valid for 1 year from purchase date.</p>
                    </div>
                    <div class="bg-[#1e1e24] rounded-xl p-5 border border-white/5">
                        <div class="w-10 h-10 rounded-lg bg-green-500/10 flex items-center justify-center mb-3">
                            <svg class="w-5 h-5 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
                        </div>
                        <h3 class="font-semibold text-white mb-1">Instant Delivery</h3>
                        <p class="text-white/40 text-sm">Receive your gift card code immediately after purchase.</p>
                    </div>
                </div>
            </div>

            {# Check Balance Section #}
            <div class="lg:col-span-2">
                <div class="bg-[#1e1e24] rounded-2xl border border-white/5 overflow-hidden sticky top-6">
                    <div class="p-6 border-b border-white/5">
                        <h2 class="text-lg font-bold text-white">Check Balance</h2>
                        <p class="text-white/40 text-sm mt-1">Enter your gift card code</p>
                    </div>
                    <div class="p-6 space-y-4">
                        <div>
                            <label class="block text-sm font-medium text-white/60 mb-2">Username</label>
                            <input
                                type="text"
                                x-model="username"
                                placeholder="Steve"
                                class="w-full px-4 py-3 rounded-xl bg-[#16161a] border border-white/5 text-white placeholder-white/20 focus:outline-none focus:border-white/20"
                            >
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-white/60 mb-2">Gift Card Code</label>
                            <input
                                type="text"
                                x-model="giftCardCode"
                                placeholder="GIFT-XXXX-XXXX"
                                class="w-full px-4 py-3 rounded-xl bg-[#16161a] border border-white/5 text-white placeholder-white/20 focus:outline-none focus:border-white/20 uppercase font-mono tracking-wide"
                                @input="giftCardCode = giftCardCode.toUpperCase()"
                            >
                        </div>

                        <button
                            @click="checkBalance()"
                            :disabled="!username || !giftCardCode || checkingBalance"
                            :class="(!username || !giftCardCode || checkingBalance) ? 'opacity-40 cursor-not-allowed' : 'hover:bg-[#3a3a44]'"
                            class="w-full py-3 rounded-xl bg-[#2a2a34] text-white font-semibold transition-all"
                        >
                            <span x-show="!checkingBalance">Check Balance</span>
                            <span x-show="checkingBalance">Checking...</span>
                        </button>

                        {# Result #}
                        <template x-if="balanceResult">
                            <div x-cloak class="p-4 rounded-xl" :class="balanceResult.valid ? 'bg-green-500/5 border border-green-500/20' : 'bg-red-500/5 border border-red-500/20'">
                                <template x-if="balanceResult.valid">
                                    <div class="text-center">
                                        <div class="text-3xl font-black text-white mb-1" x-text="'$' + balanceResult.balance.toFixed(2)"></div>
                                        <div class="text-green-400 text-sm">Available Balance</div>
                                    </div>
                                </template>
                                <template x-if="!balanceResult.valid">
                                    <p class="text-red-400 text-sm text-center" x-text="balanceResult.message"></p>
                                </template>
                            </div>
                        </template>

                        <template x-if="error">
                            <div x-cloak class="p-3 rounded-xl bg-red-500/10 border border-red-500/20">
                                <p class="text-red-400 text-sm text-center" x-text="error"></p>
                            </div>
                        </template>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}