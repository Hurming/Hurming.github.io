{# Backdrop #}
<div x-show="open" x-cloak @click="open = false" class="fixed inset-0 bg-black/70 z-50" x-transition.opacity></div>

{# Drawer #}
<div x-show="open" x-cloak
     x-transition:enter="transform transition ease-out duration-300"
     x-transition:enter-start="translate-x-full"
     x-transition:enter-end="translate-x-0"
     x-transition:leave="transform transition ease-in duration-200"
     x-transition:leave-start="translate-x-0"
     x-transition:leave-end="translate-x-full"
     class="fixed right-0 top-0 h-full w-full max-w-md bg-[#1e1e24] z-50 flex flex-col shadow-2xl">

    {# Header #}
    <div class="flex items-center justify-between px-6 h-16 border-b border-white/5">
        <h2 class="text-lg font-bold text-white">{{ trans('your_cart') }}</h2>
        <button @click="open = false" class="w-10 h-10 rounded-xl bg-[#2a2a34] hover:bg-[#3a3a44] flex items-center justify-center transition-colors">
            <svg class="w-5 h-5 text-white/60" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>
    </div>

    {# Logged in player #}
    <div class="px-6 py-4 border-b border-white/5" x-data="{ player: JSON.parse(localStorage.getItem('mcsets_player') || 'null') }" x-init="window.addEventListener('storage', () => player = JSON.parse(localStorage.getItem('mcsets_player') || 'null'))">
        <template x-if="player">
            <div class="flex items-center gap-3">
                <img :src="player.avatar_url" alt="" class="w-10 h-10 rounded-lg">
                <div class="flex-1 min-w-0">
                    <p class="text-sm text-white/50">{{ trans('purchasing_as') }}</p>
                    <p class="font-semibold text-white truncate" x-text="player.username"></p>
                </div>
                <button @click="localStorage.removeItem('mcsets_player'); localStorage.removeItem('mcsets_player_token'); player = null; window.dispatchEvent(new Event('storage'))" class="text-xs text-white/40 hover:text-white transition-colors">
                    {{ trans('change') }}
                </button>
            </div>
        </template>
        <template x-if="!player">
            <button @click="$dispatch('open-login')" class="w-full flex items-center justify-center gap-2 py-2.5 rounded-lg bg-[#2a2a34] hover:bg-[#3a3a44] text-white/70 hover:text-white transition-colors text-sm font-medium">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
                {{ trans('login_to_continue') }}
            </button>
        </template>
    </div>

    {# Items #}
    <div class="flex-1 overflow-y-auto p-6">
        <template x-if="items.length === 0">
            <div class="text-center py-16">
                <svg class="w-16 h-16 text-white/10 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
                <p class="text-white/40 font-medium">{{ trans('cart_empty') }}</p>
            </div>
        </template>

        <div class="space-y-3">
            <template x-for="(item, index) in items" :key="item.gift_card_id || item.id || index">
                <div class="flex items-center gap-4 bg-[#16161a] rounded-xl p-4">
                    <div class="w-14 h-14 rounded-xl bg-[#2a2a34] flex items-center justify-center overflow-hidden shrink-0">
                        <template x-if="item.image_path">
                            <img :src="item.image_path" alt="" class="w-full h-full object-cover">
                        </template>
                        <template x-if="!item.image_path">
                            <svg class="w-6 h-6 text-white/20" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v13m0-13V6a2 2 0 112 2h-2zm0 0V5.5A2.5 2.5 0 109.5 8H12zm-7 4h14M5 12a2 2 0 110-4h14a2 2 0 110 4M5 12v7a2 2 0 002 2h10a2 2 0 002-2v-7"/></svg>
                        </template>
                    </div>
                    <div class="flex-1 min-w-0">
                        <h4 x-text="item.name" class="font-semibold text-white truncate"></h4>
                        <p class="text-sm text-white/40">x<span x-text="item.quantity || 1"></span></p>
                    </div>
                    <div class="text-right">
                        <template x-if="item.flash_sale_active && item.original_price">
                            <div class="flex items-center gap-2 justify-end">
                                <span x-text="formatPrice(item.original_price * (item.quantity || 1))" class="text-sm text-white/40 line-through"></span>
                                <span x-text="formatPrice(item.price * (item.quantity || 1))" class="font-semibold accent-text"></span>
                            </div>
                        </template>
                        <template x-if="!item.flash_sale_active || !item.original_price">
                            <p x-text="formatPrice(item.price * (item.quantity || 1))" class="font-semibold text-white"></p>
                        </template>
                        <button @click="removeItem(item.gift_card_id || item.id)" class="text-xs text-red-400 hover:text-red-300 font-medium">{{ trans('remove') }}</button>
                    </div>
                </div>
            </template>
        </div>
    </div>

    {# Footer #}
    <div x-show="items.length > 0" class="border-t border-white/5 p-6">
        <div class="flex items-center justify-between mb-5">
            <span class="text-white/50">{{ trans('total') }}</span>
            <span x-text="formatPrice(total)" class="text-2xl font-bold text-white"></span>
        </div>
        <a href="{{ checkout_url() }}" class="block w-full py-4 rounded-xl text-center font-bold text-white transition-opacity hover:opacity-90 accent-bg">
            {{ trans('checkout') }}
        </a>
    </div>
</div>