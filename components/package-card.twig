<div class="bg-[#1e1e24] rounded-2xl overflow-hidden group">
    <a href="{{ package_url(package) }}">
        <div class="relative aspect-[4/3] bg-[#16161a] flex items-center justify-center overflow-hidden">
            {% if package.image_path %}
                <img src="{{ storage_url(package.image_path) }}" alt="{{ package.name }}" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300">
            {% else %}
                <svg class="w-16 h-16 text-white/10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v13m0-13V6a2 2 0 112 2h-2zm0 0V5.5A2.5 2.5 0 109.5 8H12zm-7 4h14M5 12a2 2 0 110-4h14a2 2 0 110 4M5 12v7a2 2 0 002 2h10a2 2 0 002-2v-7"/></svg>
            {% endif %}

            {% if is_preorder_pending(package) %}
                <span class="absolute top-3 right-3 px-2 py-1 bg-black/60 backdrop-blur-sm border border-white/10 rounded text-[10px] font-medium text-white/80 uppercase tracking-wide">{{ trans('preorder') }}</span>
            {% elseif package.flash_sale_active|default(false) %}
                <span class="absolute top-3 right-3 px-2.5 py-1 bg-gradient-to-r from-amber-500 to-red-500 rounded-lg text-xs font-bold text-white animate-pulse">⚡ {{ trans('flash_sale') }}</span>
            {% elseif package.original_price and package.original_price > package.price %}
                <span class="absolute top-3 right-3 px-2.5 py-1 bg-red-500 rounded-lg text-xs font-bold text-white">{{ trans('sale') }}</span>
            {% endif %}

            {% if package.edition is defined and package.edition != 'java' %}
                <span class="absolute top-3 left-3 px-2.5 py-1 rounded-lg text-xs font-bold {{ package.edition == 'bedrock' ? 'bg-blue-500' : 'bg-purple-500' }} text-white">
                    {{ package.edition == 'bedrock' ? 'Bedrock' : 'Both' }}
                </span>
            {% endif %}

            {# Wishlist Button #}
            {% if store.wishlist_enabled %}
            <button
                @click.prevent.stop="$store.wishlist.toggle({{ package.id }})"
                :disabled="$store.wishlist.loading === {{ package.id }}"
                class="absolute bottom-3 right-3 w-9 h-9 rounded-lg flex items-center justify-center transition-all"
                :class="$store.wishlist.isWishlisted({{ package.id }}) ? 'bg-red-500 text-white' : 'bg-black/50 backdrop-blur text-white/60 hover:text-white hover:bg-black/70'"
            >
                <svg x-show="$store.wishlist.loading !== {{ package.id }}" class="w-5 h-5" :class="$store.wishlist.isWishlisted({{ package.id }}) ? 'fill-current' : ''" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>
                <svg x-show="$store.wishlist.loading === {{ package.id }}" x-cloak class="w-4 h-4 animate-spin" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path></svg>
            </button>
            {% endif %}
        </div>
    </a>

    <div class="p-4">
        <h3 class="font-bold text-white text-center mb-3 truncate">{{ package.name }}</h3>

        <div class="text-center mb-4">
            {% if package.original_price and package.original_price > package.price %}
                <span class="text-sm text-white/30 line-through mr-2">{{ package.original_price|localized_price }}</span>
            {% endif %}
            <span class="text-xl font-bold accent-text">{{ package.price|localized_price }}</span>
        </div>

        {% if is_preorder_pending(package) %}
            <p class="text-center text-xs text-white/40 mb-3">
                {% if package.preorder_message %}
                    {{ package.preorder_message }}
                {% else %}
                    {{ trans('available') }} {{ format_preorder_date(package, 'M j') }}
                {% endif %}
            </p>
        {% endif %}

        <button
            @click="addItem({{ package|json_encode }})"
            :disabled="hasItem({{ package.id }}) || loading === {{ package.id }}"
            class="w-full py-3 rounded-xl font-bold text-sm transition-all"
            :class="hasItem({{ package.id }}) ? 'bg-white/5 text-white/30 cursor-not-allowed' : 'text-white hover:opacity-90 accent-bg'"
        >
            <span x-show="!hasItem({{ package.id }}) && loading !== {{ package.id }}">{{ is_preorder_pending(package) ? trans('preorder') : trans('add_to_cart') }}</span>
            <span x-show="hasItem({{ package.id }})" x-cloak>{{ trans('in_cart') }}</span>
            <span x-show="loading === {{ package.id }}" x-cloak>{{ trans('adding') }}...</span>
        </button>
    </div>
</div>