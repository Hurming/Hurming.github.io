<footer class="bg-[#1a1a1e] border-t border-white/5 mt-12 sm:mt-16">
    {# Main Footer #}
    <div class="max-w-7xl mx-auto px-4 sm:px-6 py-8 sm:py-12">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 lg:gap-12">
            {# Store Info #}
            <div>
                <div class="flex items-center gap-3 mb-4">
                    {% if store.logo %}
                        <img src="{{ storage_url(store.logo) }}" alt="{{ store.name }}" class="w-10 h-10 rounded-xl object-cover">
                    {% else %}
                        <div class="w-10 h-10 rounded-xl flex items-center justify-center text-white font-bold accent-bg">
                            {{ store.name|slice(0,1) }}
                        </div>
                    {% endif %}
                    <span class="text-lg font-bold text-white">{{ store.name }}</span>
                </div>
                {% if store.description %}
                    <p class="text-white/50 text-sm leading-relaxed mb-4">{{ store.description }}</p>
                {% endif %}

                {# Social Links #}
                <div class="flex items-center gap-2">
                    {% if store.discord_url %}
                        <div class="flex items-center gap-3 mb-4">
                            <div class="w-10 h-10 rounded-xl flex items-center justify-center bg-gray-800">
                                <svg class="w-6 h-6 text-white/80" viewBox="0 0 24 24" fill="currentColor">
                                    <path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"/>
                                </svg>
                            </div>
                            <span class="text-lg font-bold text-white">Our <a href="https://discord.gg/DpdxEMB" target="_blank" style="color:#5865F2; text-decoration:none;">Discord</a></span>
                        </div>
                    {% endif %}
                </div>

                <div class="flex items-center gap-3 mb-4">
                    <div class="w-10 h-10 rounded-xl flex items-center justify-center bg-gray-800">
                        <svg class="w-6 h-6 text-red-500" viewBox="0 0 24 24" fill="currentColor">
                            <path d="M23.498 6.186a2.999 2.999 0 0 0-2.113-2.12C19.505 3.5 12 3.5 12 3.5s-7.505 0-9.385.566a2.999 2.999 0 0 0-2.113 2.12A31.73 31.73 0 0 0 0 12a31.73 31.73 0 0 0 .502 5.814 2.999 2.999 0 0 0 2.113 2.12C4.495 20.5 12 20.5 12 20.5s7.505 0 9.385-.566a2.999 2.999 0 0 0 2.113-2.12A31.73 31.73 0 0 0 24 12a31.73 31.73 0 0 0-.502-5.814zM9.75 15.5v-7l6.5 3.5-6.5 3.5z"/>
                        </svg>
                    </div>
                    <span class="text-lg font-bold text-white">
                        Our <a href="https://www.youtube.com/@Hurming" target="_blank" class="text-red-500 hover:text-red-400 transition-colors">YouTube</a>
                    </span>
                </div>

                <div class="flex items-center gap-3 mb-4">
                    <div class="w-10 h-10 rounded-xl flex items-center justify-center bg-gray-800">
                        <svg class="w-6 h-6 text-white" viewBox="0 0 24 24" fill="currentColor">
                            <path d="M12.004 2c.683 0 1.237.554 1.237 1.237v1.982a5.58 5.58 0 0 0 3.255 1.63c.613.07 1.083.597 1.083 1.214v1.25c0 .71-.59 1.276-1.297 1.214a8.126 8.126 0 0 1-3.041-.894v6.492c0 3.01-2.443 5.453-5.453 5.453A5.456 5.456 0 0 1 2.335 15.4c0-3.01 2.443-5.453 5.453-5.453.322 0 .64.028.951.083v2.64a2.99 2.99 0 0 0-.951-.155 2.883 2.883 0 0 0 0 5.766 2.883 2.883 0 0 0 2.883-2.883V3.237c0-.683.554-1.237 1.237-1.237z"/>
                        </svg>
                    </div>
                    <span class="text-lg font-bold text-white">
                        Our <a href="https://www.tiktok.com/@hurming" target="_blank" class="hover:text-white/80 transition-colors">TikTok</a>
                    </span>
                </div>
            </div>

            {# Quick Links (Categories) #}
            <div>
                <h4 class="text-base font-extrabold text-white uppercase tracking-widest mb-1 pl-3">{{ trans('quick_links') }}</h4>
                <ul class="space-y-0.1 pl-3">
                    <li class="relative pl-4"><span class="absolute left-1 text-white/40 select-none">•</span><a href="/" class="block text-base text-white/70 hover:text-white transition-colors">{{ trans('home') }}</a></li>
                    {% for category in categories|default([])|slice(0,5) %}
                        <li class="relative pl-4"><span class="absolute left-1 text-white/40 select-none">•</span><a href="{{ category_url(category) }}" class="block text-base text-white/70 hover:text-white transition-colors">{{ category.name }}</a></li>
                    {% endfor %}
                </ul>
            </div>

            {# Support (Pages) #}
            <div>
                <h4 class="text-base font-extrabold text-white uppercase tracking-widest mb-1 pl-3">{{ trans('support') }}</h4>
                <ul class="space-y-0.1 pl-3">
                    <li class="relative pl-4"><span class="absolute left-1 text-white/40 select-none">•</span><a href="/p/terms" class="block text-base text-white/70 hover:text-white transition-colors">{{ trans('terms_of_service') }}</span></li>
                    <li class="relative pl-4"><span class="absolute left-1 text-white/40 select-none">•</span><a href="/p/privacy" class="block text-base text-white/70 hover:text-white transition-colors">{{ trans('privacy_policy') }}</span></li>
                    <li class="relative pl-4"><span class="absolute left-1 text-white/40 select-none">•</span><a href="/p/refunds" class="block text-base text-white/70 hover:text-white transition-colors">{{ trans('refund_policy') }}</span></li>
                    {# {% if footer_pages|default([])|length > 0 %}
                        {% for page in footer_pages %}
                            <li class="relative pl-4"><span class="absolute left-1 text-white/40 select-none">•</span><a href="/p/{{ page.slug }}"class="block text-base text-white/70 hover:text-white transition-colors">{{ page.title }}</a></li>
                        {% endfor %}
                    {% else %}
                        <li class="relative pl-4"><span class="absolute left-1 text-white/40 select-none">•</span><a href="/p/terms" class="block text-base text-white/70 hover:text-white transition-colors">{{ trans('terms_of_service') }}</span></li>
                        <li class="relative pl-4"><span class="absolute left-1 text-white/40 select-none">•</span><a href="/p/privacy" class="block text-base text-white/70 hover:text-white transition-colors">{{ trans('privacy_policy') }}</span></li>
                        <li class="relative pl-4"><span class="absolute left-1 text-white/40 select-none">•</span><a href="/p/refunds" class="block text-base text-white/70 hover:text-white transition-colors">{{ trans('refund_policy') }}</span></li>
                    {% endif %} #}
                </ul>
            </div>
        </div>
    </div>

    {# Bottom Bar - MCSETS BRANDING REQUIRED #}
    <div class="border-t border-white/5">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 py-4 sm:py-5">
            <div class="flex flex-col sm:flex-row items-center justify-between gap-2 sm:gap-3">
                <div class="text-xs sm:text-sm text-white/40 text-center sm:text-left">
                    &copy; {{ "now"|date("Y") }} {{ store.name }}. {{ trans('all_rights_reserved') }}
                </div>
                <div class="flex items-center gap-2 text-xs sm:text-sm text-white/40">
                    <span>{{ trans('powered_by') }}</span>
                    <a href="https://mcsets.com" target="_blank" rel="noopener noreferrer" class="font-semibold text-white/60 hover:text-white transition-colors">MCsets</a>
                </div>
            </div>
        </div>
    </div>
</footer>