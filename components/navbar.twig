<div class="bg-[#1e1e24] border-b border-white/5" x-data="{ ...playerAuth(), mobileMenuOpen: false }" @open-login.window="showLoginModal = true" @toggle-mobile-menu.window="mobileMenuOpen = true">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
        <div class="flex items-center justify-between h-14 lg:h-16">
            {# Left - Store Logo/Name #}
            <div class="flex items-center gap-2 sm:gap-3">
                {# Mobile Menu Button - Only visible on mobile #}
                <button @click="mobileMenuOpen = true" class="lg:hidden w-10 h-10 rounded-xl bg-[#2a2a34] hover:bg-[#3a3a44] flex items-center justify-center transition-colors">
                    <svg class="w-5 h-5 text-white/60" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
                </button>
                {# Store Logo/Name - Always visible #}
                <a href="/" class="flex items-center gap-2">
                    {% if store.logo %}
                        <img src="{{ storage_url(store.logo) }}" alt="{{ store.name }}" class="w-8 h-8 rounded-lg object-cover">
                    {% endif %}
                    <span class="hidden sm:block font-bold text-white text-sm">{{ store.name }}</span>
                </a>
                {# Desktop only buttons #}
                {% if store.discord_url %}
                <a href="{{ store.discord_url }}" target="_blank" rel="noopener noreferrer" class="hidden lg:flex w-10 h-10 rounded-xl bg-[#2a2a34] hover:bg-[#5865F2] items-center justify-center transition-colors">
                    <svg class="w-5 h-5 text-white/60" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"/>
                    </svg>
                </a>
                {% endif %}
                {% if gift_cards and gift_cards.enabled %}
                <a href="/giftcards" class="hidden lg:flex w-10 h-10 rounded-xl bg-[#2a2a34] hover:bg-gradient-to-br hover:from-purple-500 hover:to-pink-500 items-center justify-center transition-all group" title="Gift Cards">
                    <svg class="w-5 h-5 text-white/60 group-hover:text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v13m0-13V6a2 2 0 112 2h-2zm0 0V5.5A2.5 2.5 0 109.5 8H12zm-7 4h14M5 12a2 2 0 110-4h14a2 2 0 110 4M5 12v7a2 2 0 002 2h10a2 2 0 002-2v-7"/>
                    </svg>
                </a>
                {% endif %}
            </div>

            {# Right Side #}
            <div class="flex items-center gap-1.5 sm:gap-2 lg:gap-3">
                {# Language Switcher - Compact on mobile #}
                {# <div class="relative" x-data="{ langOpen: false }">
                    <button @click="langOpen = !langOpen" @click.outside="langOpen = false" class="h-9 sm:h-10 px-2 sm:px-3 rounded-lg sm:rounded-xl bg-[#2a2a34] hover:bg-[#3a3a44] flex items-center gap-1 sm:gap-2 transition-colors">
                        <span class="text-sm sm:text-base">{{ languages[language].flag|default('🇺🇸') }}</span>
                        <svg class="w-3 h-3 sm:w-4 sm:h-4 text-white/40" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                    </button>
                    <div x-show="langOpen" x-cloak x-transition class="absolute right-0 mt-2 w-48 py-2 bg-[#1e1e24] rounded-xl border border-white/10 shadow-xl z-50 max-h-64 overflow-y-auto scrollbar-hide">
                        {% for code, lang in languages %}
                        <a href="{{ language_url(code) }}" class="flex items-center gap-3 px-4 py-2 hover:bg-white/5 transition-colors {% if code == language %}bg-white/5{% endif %}">
                            <span class="text-base">{{ lang.flag }}</span>
                            <span class="text-sm text-white/80">{{ lang.native }}</span>
                        </a>
                        {% endfor %}
                    </div>
                </div> #}

                {# Currency Switcher - Compact on mobile #}
                <div class="relative" x-data="{ currOpen: false }">
                    <button @click="currOpen = !currOpen" @click.outside="currOpen = false" class="h-9 sm:h-10 px-2 sm:px-3 rounded-lg sm:rounded-xl bg-[#2a2a34] hover:bg-[#3a3a44] flex items-center gap-1 sm:gap-2 transition-colors">
                        <span class="text-xs sm:text-sm font-medium text-white/80">{{ currencies[currency].symbol|default('$') }}</span>
                        <svg class="w-3 h-3 sm:w-4 sm:h-4 text-white/40" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                    </button>
                    <div x-show="currOpen" x-cloak x-transition class="absolute right-0 mt-2 w-56 py-2 bg-[#1e1e24] rounded-xl border border-white/10 shadow-xl z-50 max-h-64 overflow-y-auto scrollbar-hide">
                        {% for code, curr in currencies %}
                        <a href="{{ currency_url(code) }}" class="flex items-center justify-between px-4 py-2 hover:bg-white/5 transition-colors {% if code == currency %}bg-white/5{% endif %}">
                            <span class="text-sm text-white/80">{{ curr.name }}</span>
                            <span class="text-sm font-medium text-white/60">{{ curr.symbol }} {{ code }}</span>
                        </a>
                        {% endfor %}
                    </div>
                </div>

                {# Discord Link (for role sync) - Hide on mobile #}
                {% if store.discord_enabled and store.discord_role_sync_enabled %}
                <a href="/discord/link" class="hidden sm:flex h-10 px-3 lg:px-4 rounded-xl bg-[#5865F2] hover:bg-[#4752C4] items-center gap-2 transition-colors" title="Link Discord for roles">
                    <svg class="w-5 h-5 text-white" viewBox="0 0 24 24" fill="currentColor"><path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"/></svg>
                    <span class="hidden lg:inline text-sm font-medium text-white">Link Discord</span>
                </a>
                {% endif %}

                {# Cart - Hidden on mobile (in bottom nav) #}
                <button @click="$dispatch('toggle-cart')" class="hidden lg:flex h-10 px-3 lg:px-4 rounded-xl bg-[#2a2a34] hover:bg-[#3a3a44] items-center gap-2 transition-colors relative">
                    <svg class="w-5 h-5 text-white/60" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
                    <span x-show="$store.cart && $store.cart.count > 0" x-text="$store.cart?.count" x-cloak class="min-w-[20px] h-5 px-1.5 rounded-md text-xs font-bold text-white flex items-center justify-center accent-bg"></span>
                </button>

                {# Player Account / Login - Compact on mobile #}
                <template x-if="player">
                    <a href="/account" class="flex items-center gap-1.5 sm:gap-2 lg:gap-3 h-9 sm:h-10 pl-1.5 pr-2 sm:pl-2 sm:pr-3 lg:pl-3 lg:pr-4 rounded-lg sm:rounded-xl bg-[#2a2a34] hover:bg-[#3a3a44] transition-colors">
                        <img :src="player.avatar_url" alt="" class="w-6 h-6 sm:w-7 sm:h-7 lg:w-8 lg:h-8 rounded-md sm:rounded-lg object-cover">
                        <div class="hidden lg:block">
                            <div class="text-sm font-semibold text-white leading-tight" x-text="player.username"></div>
                            <div class="text-xs text-white/40 leading-tight">{{ trans('my_account') }}</div>
                        </div>
                    </a>
                </template>
                <template x-if="!player">
                    <button @click="showLoginModal = true" class="flex items-center gap-1.5 sm:gap-2 h-9 sm:h-10 px-2 sm:px-3 lg:pl-3 lg:pr-4 rounded-lg sm:rounded-xl bg-[#2a2a34] hover:bg-[#3a3a44] transition-colors">
                        <div class="w-6 h-6 sm:w-7 sm:h-7 lg:w-8 lg:h-8 rounded-md sm:rounded-lg bg-[#3a3a44] flex items-center justify-center">
                            <svg class="w-3.5 h-3.5 sm:w-4 sm:h-4 text-white/40" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
                        </div>
                        <span class="hidden lg:block text-sm font-semibold text-white">{{ trans('login') }}</span>
                    </button>
                </template>
            </div>
        </div>
    </div>

    {# Login Modal #}
    <div x-show="showLoginModal" x-cloak class="fixed inset-0 z-50 flex items-center justify-center p-4" @keydown.escape.window="showLoginModal = false">
        {# Backdrop #}
        <div class="absolute inset-0 bg-black/70" @click="showLoginModal = false" x-transition.opacity></div>

        {# Modal #}
        <div class="relative bg-[#1e1e24] rounded-2xl w-full max-w-md overflow-hidden shadow-2xl"
             x-transition:enter="ease-out duration-300"
             x-transition:enter-start="opacity-0 scale-95"
             x-transition:enter-end="opacity-100 scale-100"
             x-transition:leave="ease-in duration-200"
             x-transition:leave-start="opacity-100 scale-100"
             x-transition:leave-end="opacity-0 scale-95">

            {# Header #}
            <div class="p-6 border-b border-white/5">
                <div class="flex items-center justify-between">
                    <h3 class="text-xl font-bold text-white">{{ trans('login_with_minecraft') }}</h3>
                    <button @click="showLoginModal = false" class="w-8 h-8 rounded-lg bg-[#2a2a34] hover:bg-[#3a3a44] flex items-center justify-center transition-colors">
                        <svg class="w-4 h-4 text-white/60" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                    </button>
                </div>
            </div>

            {# Content #}
            <div class="p-6 text-center">
                <div class="w-20 h-20 mx-auto mb-4 rounded-2xl bg-[#2a2a34] flex items-center justify-center">
                    <svg class="w-10 h-10 text-white/40" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                    </svg>
                </div>
                <p class="text-white/60 mb-6">{{ trans('enter_username') }}</p>
                <div class="mb-4">
                    <input type="text" x-model="loginUsername" @keydown.enter="loginWithUsername()"
                           placeholder="{{ trans('username') }}"
                           class="w-full px-4 py-3 bg-black/30 border border-white/10 rounded-xl text-white text-center text-lg placeholder-white/30 focus:outline-none focus:border-white/20"
                           maxlength="16">
                </div>
                <p x-show="loginError" x-text="loginError" x-cloak class="text-red-400 text-sm mb-4"></p>
                <button @click="loginWithUsername()" :disabled="loginLoading || loginUsername.length < 3"
                        class="w-full py-3 rounded-xl font-bold text-white transition-all disabled:opacity-50 accent-bg">
                    <span x-show="!loginLoading">{{ trans('login') }}</span>
                    <span x-show="loginLoading" x-cloak class="flex items-center justify-center gap-2">
                        <svg class="w-5 h-5 animate-spin" fill="none" viewBox="0 0 24 24">
                            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
                        </svg>
                        {{ trans('logging_in') }}
                    </span>
                </button>
            </div>
        </div>
    </div>

    {# Mobile Sidebar Drawer #}
    <div x-show="mobileMenuOpen" x-cloak @click="mobileMenuOpen = false" class="lg:hidden fixed inset-0 bg-black/70 z-50" x-transition.opacity></div>
    <div x-show="mobileMenuOpen" x-cloak
         x-transition:enter="transform transition ease-out duration-300"
         x-transition:enter-start="-translate-x-full"
         x-transition:enter-end="translate-x-0"
         x-transition:leave="transform transition ease-in duration-200"
         x-transition:leave-start="translate-x-0"
         x-transition:leave-end="-translate-x-full"
         class="lg:hidden fixed left-0 top-0 h-full w-[85%] max-w-[320px] bg-[#16161a] z-50 flex flex-col shadow-2xl overflow-y-auto">

        {# Header #}
        <div class="flex items-center justify-between px-5 h-16 border-b border-white/5 shrink-0">
            <div class="flex items-center gap-3">
                {% if store.logo %}
                    <img src="{{ storage_url(store.logo) }}" alt="{{ store.name }}" class="w-8 h-8 rounded-lg object-cover">
                {% endif %}
                <span class="font-bold text-white">{{ store.name }}</span>
            </div>
            <button @click="mobileMenuOpen = false" class="w-10 h-10 rounded-xl bg-[#2a2a34] hover:bg-[#3a3a44] flex items-center justify-center transition-colors">
                <svg class="w-5 h-5 text-white/60" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
            </button>
        </div>

        {# Menu Content #}
        <div class="flex-1 p-4 space-y-4 overflow-y-auto">
            {# Categories #}

            <div class="bg-[#1e1e24] rounded-2xl overflow-hidden border border-white/[0.03] shadow-2xl" x-data="{ menuExpanded: true }">
                <button @click="menuExpanded = !menuExpanded" class="w-full p-6 flex flex-col items-center group hover:bg-white/[0.02] transition-all duration-300">
                    <div class="flex items-center justify-center gap-2">
                        <h3 class="text-xl font-bold text-white tracking-tight">{{ trans('store_menu') }}</h3>
                        <svg :class="menuExpanded ? 'rotate-180' : ''" class="w-5 h-5 text-white/30 transition-transform duration-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                        </svg>
                    </div>
                </button>

                <div x-show="menuExpanded" x-collapse class="border-t border-white/[0.05] p-3 space-y-1.5 bg-black/10">
                    <a href="/" 
                    class="relative flex items-center justify-between px-4 py-3 rounded-xl transition-all duration-300 group overflow-hidden
                    {{ not active_category ? 'bg-white/[0.08] text-white' : 'text-white/40 hover:text-white hover:bg-white/[0.03]' }}">
                        
                        <div class="flex items-center gap-3 relative z-10 transition-transform duration-300 group-hover:translate-x-1">
                            <div class="w-8 h-8 rounded-lg flex items-center justify-center {{ not active_category ? 'bg-blue-500/20 text-blue-400' : 'bg-white/5 text-current' }}">
                                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                            </div>
                            <span class="font-semibold">{{ trans('home') }}</span>
                        </div>

                        {% if not active_category %}
                            <div class="absolute left-0 top-3 bottom-3 w-1 bg-blue-500 rounded-r-full shadow-[0_0_15px_rgba(59,130,246,0.8)]"></div>
                        {% endif %}
                    </a>

                    {% for category in categories %}
                    <a href="{{ category_url(category) }}" 
                    class="relative flex items-center justify-between px-4 py-3 rounded-xl transition-all duration-300 group overflow-hidden
                    {{ active_category.id == category.id ? 'bg-white/[0.08] text-white' : 'text-white/40 hover:text-white hover:bg-white/[0.03]' }}">
                        
                        <div class="flex items-center gap-3 relative z-10 transition-transform duration-300 group-hover:translate-x-1">
                            <div class="w-8 h-8 rounded-lg flex items-center justify-center {{ active_category.id == category.id ? 'bg-blue-500/20 text-blue-400' : 'bg-white/5 text-current group-hover:bg-white/10' }}">
                                {% if category.slug == 'ranks' %}
                                    <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m2 4 3 12h14l3-12-6 7-4-7-4 7-6-7zm3 16h14"/></svg>
                                {% elseif category.slug == 'keys' %}
                                    <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="7.5" cy="15.5" r="5.5"/><path d="m21 2-9.6 9.6"/><path d="m15.5 7.5 3 3L22 7l-3-3"/></svg>
                                {% else %}
                                    <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><line x1="3" x2="21" y1="9" y2="9"/><line x1="9" x2="9" y1="21" y2="9"/></svg>
                                {% endif %}

                            </div>
                            <span class="font-semibold">{{ category.name }}</span>
                        </div>

                        {% if active_category.id == category.id %}
                            <div class="absolute left-0 top-3 bottom-3 w-1 bg-blue-500 rounded-r-full shadow-[0_0_15px_rgba(59,130,246,0.8)]"></div>
                        {% endif %}

                        <span class="text-[10px] px-2 py-0.5 rounded-md bg-white/5 border border-white/10 font-bold opacity-60">
                            {{ category.packages_count|default(0) }}
                        </span>
                    </a>
                    {% endfor %}
                </div>
            </div>

            <div class="bg-[#1e1e24] rounded-2xl overflow-hidden border border-white/[0.03] shadow-2xl" x-data="{ menuExpanded: true }">
                <button @click="menuExpanded = !menuExpanded" class="w-full p-6 flex flex-col items-center group hover:bg-white/[0.02] transition-all duration-300">
                    <div class="flex items-center justify-center gap-2">
                        <h3 class="text-xl font-bold text-white tracking-tight">Application Center</h3>
                        <svg :class="menuExpanded ? 'rotate-180' : ''" class="w-5 h-5 text-white/30 transition-transform duration-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                        </svg>
                    </div>
                </button>

                <div x-show="menuExpanded" x-collapse class="border-t border-white/[0.05] p-3 space-y-1.5 bg-black/10">
                    
                    <a href="/p/social" class="relative flex items-center justify-between px-4 py-3 rounded-xl transition-all duration-300 group overflow-hidden hover:bg-white/5">
                        <div class="flex items-center gap-3 relative z-10 transition-transform duration-300 group-hover:translate-x-1">
                            <div class="w-8 h-8 rounded-lg flex items-center justify-center bg-emerald-500/20 text-emerald-400">
                                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                                    <circle cx="9" cy="7" r="4"></circle>
                                    <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
                                    <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
                                </svg>
                            </div>
                            <span class="font-semibold text-white/90">Apply for Social</span>
                        </div>
                        <svg class="w-4 h-4 text-white/20 group-hover:text-white/50 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
                    </a>

                    <a href="/p/staff" class="relative flex items-center justify-between px-4 py-3 rounded-xl transition-all duration-300 group overflow-hidden hover:bg-white/5">
                        <div class="flex items-center gap-3 relative z-10 transition-transform duration-300 group-hover:translate-x-1">
                            <div class="w-8 h-8 rounded-lg flex items-center justify-center bg-blue-500/20 text-blue-400">
                                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
                                    <path d="m9 12 2 2 4-4"></path>
                                </svg>
                            </div>
                            <span class="font-semibold text-white/90">Apply for Staff</span>
                        </div>
                        <svg class="w-4 h-4 text-white/20 group-hover:text-white/50 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
                    </a>

                </div>
            </div>

            {% if donations.enabled|default(false) %}
            {# Donation Goal (if set) #}
            {% if donation_goal %}
            <div class="bg-[#1e1e24] rounded-2xl p-4">
                <div class="flex items-center gap-3 mb-3">
                    <div class="w-10 h-10 rounded-xl bg-red-500/10 flex items-center justify-center">
                        <svg class="w-5 h-5 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>
                    </div>
                    <div>
                        <p class="text-[10px] text-white/40 uppercase tracking-wider font-semibold">{{ donation_goal.name }}</p>
                        <p class="font-bold text-white text-sm">{{ price(donation_goal.current) }} / {{ price(donation_goal.target) }}</p>
                    </div>
                </div>
                <div class="w-full bg-white/5 rounded-full h-2.5 overflow-hidden">
                    <div class="h-full bg-gradient-to-r from-red-500 to-pink-500 rounded-full transition-all duration-500" style="width: {{ donation_goal.percentage }}%"></div>
                </div>
                <p class="text-white/30 text-xs mt-2 text-center">{{ donation_goal.percentage }}% Complete</p>
            </div>
            {% endif %}

            {# Top Donator #}
            <div class="bg-[#1e1e24] rounded-2xl p-4">
                <div class="flex items-center gap-3">
                    <img src="{{ top_donator ? top_donator.avatar_url : 'https://mc-heads.net/avatar/MHF_Question/40' }}" alt="" class="w-10 h-10 rounded-xl">
                    <div>
                        <p class="text-[10px] text-white/40 uppercase tracking-wider font-semibold">Top Donator</p>
                        <p class="font-bold text-white text-sm">{{ top_donator.username|default('Nobody yet') }}</p>
                    </div>
                </div>
            </div>

            {# Recent Payments #}
            <div class="bg-[#1e1e24] rounded-2xl p-4">
                <div class="flex items-center gap-3 mb-3">
                    <div class="w-10 h-10 rounded-xl bg-[#2a2a34] flex items-center justify-center">
                        <svg class="w-5 h-5 text-white/40" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v13m0-13V6a2 2 0 112 2h-2zm0 0V5.5A2.5 2.5 0 109.5 8H12zm-7 4h14M5 12a2 2 0 110-4h14a2 2 0 110 4M5 12v7a2 2 0 002 2h10a2 2 0 002-2v-7"/></svg>
                    </div>
                    <div>
                        <p class="text-[10px] text-white/40 uppercase tracking-wider font-semibold">Recent Payments</p>
                        <p class="font-bold text-white text-sm">Payment Feed</p>
                    </div>
                </div>
                <div class="flex gap-2">
                    {% if recent_payments|default([])|length > 0 %}
                        {% for payment in recent_payments|slice(0, 4) %}
                            <img src="{{ mc_head(payment.username, 40) }}" alt="{{ payment.username }}" class="w-10 h-10 rounded-xl" title="{{ payment.username }} - {{ price(payment.amount) }}">
                        {% endfor %}
                    {% else %}
                        <div class="w-10 h-10 rounded-xl bg-[#2a2a34]"></div>
                        <div class="w-10 h-10 rounded-xl bg-[#2a2a34]"></div>
                        <div class="w-10 h-10 rounded-xl bg-[#2a2a34]"></div>
                    {% endif %}
                </div>
            </div>
            {% endif %}

            {# Gift Cards Quick Access #}
            {% if gift_cards.enabled|default(false) %}
            <a href="/giftcards" @click="mobileMenuOpen = false" class="block bg-gradient-to-r from-purple-500/10 to-pink-500/10 border border-purple-500/20 rounded-2xl p-4">
                <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-xl bg-purple-500/20 flex items-center justify-center">
                        <svg class="w-5 h-5 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v13m0-13V6a2 2 0 112 2h-2zm0 0V5.5A2.5 2.5 0 109.5 8H12zm-7 4h14M5 12a2 2 0 110-4h14a2 2 0 110 4M5 12v7a2 2 0 002 2h10a2 2 0 002-2v-7"/></svg>
                    </div>
                    <div>
                        <p class="font-bold text-white text-sm">Gift Cards</p>
                        <p class="text-white/50 text-xs">Buy or check balance</p>
                    </div>
                </div>
            </a>
            {% endif %}

            {# Discord Link #}
            {% if store.discord_url %}
            <a href="{{ store.discord_url }}" target="_blank" rel="noopener noreferrer" class="block bg-[#5865F2]/10 border border-[#5865F2]/20 rounded-2xl p-4">
                <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-xl bg-[#5865F2] flex items-center justify-center">
                        <svg class="w-5 h-5 text-white" viewBox="0 0 24 24" fill="currentColor">
                            <path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"/>
                        </svg>
                    </div>
                    <div>
                        <p class="font-bold text-white text-sm">Join Discord</p>
                        <p class="text-white/50 text-xs">Get support & updates</p>
                    </div>
                </div>
            </a>
            {% endif %}

            {# Language & Currency Switchers #}
            <div class="bg-[#1e1e24] rounded-2xl p-4 space-y-3">
                <p class="text-[10px] text-white/40 uppercase tracking-wider font-semibold">Settings</p>
                {# Language Selector #}
                {# <div x-data="{ langOpen: false }" class="relative">
                    <button @click="langOpen = !langOpen" class="w-full flex items-center justify-between px-3 py-2.5 rounded-xl bg-[#2a2a34] hover:bg-[#3a3a44] transition-colors">
                        <div class="flex items-center gap-2">
                            <span class="text-lg">{{ languages[language].flag|default('🇺🇸') }}</span>
                            <span class="text-sm text-white/80">{{ languages[language].native|default('English') }}</span>
                        </div>
                        <svg class="w-4 h-4 text-white/40 transition-transform" :class="langOpen ? 'rotate-180' : ''" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                    </button>
                    <div x-show="langOpen" x-cloak x-transition class="mt-2 py-2 bg-[#2a2a34] rounded-xl max-h-48 overflow-y-auto">
                        {% for code, lang in languages %}
                        <a href="{{ language_url(code) }}" class="flex items-center gap-2 px-3 py-2 hover:bg-white/5 transition-colors {% if code == language %}bg-white/5{% endif %}">
                            <span class="text-base">{{ lang.flag }}</span>
                            <span class="text-sm text-white/80">{{ lang.native }}</span>
                        </a>
                        {% endfor %}
                    </div>
                </div> #}
                {# Currency Selector #}
                <div x-data="{ currOpen: false }" class="relative">
                    <button @click="currOpen = !currOpen" class="w-full flex items-center justify-between px-3 py-2.5 rounded-xl bg-[#2a2a34] hover:bg-[#3a3a44] transition-colors">
                        <div class="flex items-center gap-2">
                            <span class="text-sm font-medium text-white/80">{{ currencies[currency].symbol|default('$') }}</span>
                            <span class="text-sm text-white/80">{{ currencies[currency].name|default('US Dollar') }}</span>
                        </div>
                        <svg class="w-4 h-4 text-white/40 transition-transform" :class="currOpen ? 'rotate-180' : ''" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                    </button>
                    <div x-show="currOpen" x-cloak x-transition class="mt-2 py-2 bg-[#2a2a34] rounded-xl max-h-48 overflow-y-auto">
                        {% for code, curr in currencies %}
                        <a href="{{ currency_url(code) }}" class="flex items-center justify-between px-3 py-2 hover:bg-white/5 transition-colors {% if code == currency %}bg-white/5{% endif %}">
                            <span class="text-sm text-white/80">{{ curr.name }}</span>
                            <span class="text-xs text-white/50">{{ curr.symbol }} {{ code }}</span>
                        </a>
                        {% endfor %}
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>