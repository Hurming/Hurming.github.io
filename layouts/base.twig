<!DOCTYPE html>
<html lang="en" class="overflow-x-hidden">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="csrf-token" content="{{ csrf_token }}">
    <title>{% block title %}{{ store.name }}{% endblock %}</title>

    {# Favicon #}
    {% if store.logo %}
    <link rel="icon" type="image/png" href="{{ storage_url(store.logo) }}">
    <link rel="apple-touch-icon" href="{{ storage_url(store.logo) }}">
    {% endif %}

    {# SEO Meta Tags #}
    <meta name="description" content="{% block meta_description %}{{ store.description|default('Welcome to Arab Throne - unlock premium ranks, powerful crates, and exclusive rewards.') }}{% endblock %}">
    <meta name="robots" content="index, follow">
    {% if store.keywords is defined and store.keywords %}
    <meta name="keywords" content="{{ store.keywords }}">
    {% endif %}

    {# Open Graph / Facebook #}
    <meta property="og:type" content="website">
    <meta property="og:site_name" content="{{ store.name }}">
    <meta property="og:title" content="{% block og_title %}{{ store.name }}{% endblock %}">
    <meta property="og:description" content="{% block og_description %}{{ store.description|default('Welcome to Arab Throne - unlock premium ranks, powerful crates, and exclusive rewards.') }}{% endblock %}">
    {% if store.logo %}
    <meta property="og:image" content="{{ storage_url(store.logo) }}">
    {% endif %}

    {# Twitter Card #}
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="{{ store.name }}">
    <meta name="twitter:description" content="{{ store.description|default('Welcome to ' ~ store.name) }}">
    {% if store.logo %}
    <meta name="twitter:image" content="{{ storage_url(store.logo) }}">
    {% endif %}

    {# Theme Color #}
    <meta name="theme-color" content="#16161a">

    {# Platform-controlled assets - themes cannot modify these #}
    {{ mcsets_head() }}

    {# Upgrade store - must be defined before Alpine processes the DOM #}
    <script>
    document.addEventListener('alpine:init', () => {
        Alpine.store('upgrades', {
            offers: [],
            loading: false,
            showModal: false,
            currentOffer: null,
            currentUsername: localStorage.getItem('mcsets_username') || null,
            dismissedOffers: JSON.parse(localStorage.getItem('dismissedUpgrades') || '[]'),
            async fetchOffers(username) {
                const checkUsername = username || this.currentUsername;
                if (this.loading) return;
                this.loading = true;
                try {
                    let url = '/api/auth/upgrade-offers';
                    if (checkUsername) url += '?username=' + encodeURIComponent(checkUsername);
                    const response = await fetch(url, { credentials: 'include' });
                    if (response.ok) {
                        const data = await response.json();
                        this.offers = data.offers || [];
                        if (data.player?.username) this.currentUsername = data.player.username;
                    }
                } catch (e) { console.error('Failed to fetch upgrade offers:', e); }
                this.loading = false;
            },
            setUsername(username) {
                this.currentUsername = username;
                localStorage.setItem('mcsets_username', username);
                this.fetchOffers(username);
            },
            formatPrice(amount) {
                return new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD' }).format(amount || 0);
            },
            showUpgradeModal(offer) {
                this.currentOffer = offer;
                this.showModal = true;
            },
            closeModal() {
                this.showModal = false;
                this.currentOffer = null;
            },
            dismissOffer(packageId) {
                this.dismissedOffers.push(packageId);
                localStorage.setItem('dismissedUpgrades', JSON.stringify(this.dismissedOffers));
                this.showModal = false;
                this.currentOffer = null;
            }
        });
    });
    </script>
    {% block head %}{% endblock %}
</head>
<body class="min-h-screen bg-[#16161a] text-white pb-20 lg:pb-0 overflow-x-hidden" x-data="cartStore()" @toggle-cart.window="open = !open">
    {# Sandbox Mode Banner #}
    {% if store.sandbox_mode %}
    <div class="bg-amber-500 text-black px-4 py-2 text-center text-sm font-medium">
        <span class="inline-flex items-center gap-2">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/></svg>
            Sandbox Mode — Purchases are test-only and will not charge your card
        </span>
    </div>
    {% endif %}

    {% block content %}{% endblock %}

    {% include 'components/cart-drawer.twig' %}
    {% include 'components/footer.twig' %}

    {# Mobile Bottom Navigation Bar #}
    <div class="lg:hidden fixed bottom-0 left-0 right-0 bg-[#1e1e24] border-t border-white/10 z-40 safe-area-inset-bottom">
        <div class="flex items-center justify-around h-16 px-2">
            <a href="/" class="flex flex-col items-center gap-1 px-4 py-2 rounded-xl text-white/60 hover:text-white transition-colors">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
                <span class="text-[10px] font-medium">Home</span>
            </a>
            <button @click="$dispatch('toggle-mobile-menu')" class="flex flex-col items-center gap-1 px-4 py-2 rounded-xl text-white/60 hover:text-white transition-colors">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
                <span class="text-[10px] font-medium">Menu</span>
            </button>
            <button @click="$dispatch('toggle-cart')" class="flex flex-col items-center gap-1 px-4 py-2 rounded-xl text-white/60 hover:text-white transition-colors relative">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
                <span class="text-[10px] font-medium">Cart</span>
                <span x-show="$store.cart && $store.cart.count > 0" x-text="$store.cart?.count" x-cloak class="absolute -top-1 -right-1 min-w-[18px] h-[18px] px-1 rounded-full text-[10px] font-bold text-white flex items-center justify-center accent-bg"></span>
            </button>
            <a href="/account" class="flex flex-col items-center gap-1 px-4 py-2 rounded-xl text-white/60 hover:text-white transition-colors">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
                <span class="text-[10px] font-medium">Account</span>
            </a>
        </div>
    </div>

    {# Platform-controlled cart logic - themes cannot modify this #}
    {{ mcsets_scripts() }}
    {% block scripts %}{% endblock %}
</body>
</html>